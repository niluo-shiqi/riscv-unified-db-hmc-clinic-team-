#!/usr/bin/env bash

ROOT=$(dirname "$(dirname "$(realpath "${BASH_SOURCE[0]}")")")

rm -rf                   \
  "${ROOT}"/.stamps      \
  "${ROOT}"/.home        \
  "${ROOT}"/.docker-home \
  "${ROOT}"/.cache       \
  "${ROOT}"/gen          \
  "${ROOT}"/sorbet       \
  "${ROOT}"/tools/ruby-gems/idlc/.sorbet-cache \
  "${ROOT}"/tools/ruby-gems/udb/.sorbet-cache \
  "${ROOT}"/tools/ruby-gems/udb-gen/.sorbet-cache

# Remove bundler state but preserve the checked-in config
find "${ROOT}"/.bundle -not -name config -delete 2>/dev/null || true
