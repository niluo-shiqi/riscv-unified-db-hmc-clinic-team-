# Source helper functions and modular subcommand files
# shellcheck source=.chore/helpers.sh
source "${UDB_ROOT}/bin/.chore/helpers.sh"
# shellcheck source=.chore/container.sh
source "${UDB_ROOT}/bin/.chore/container.sh"
# shellcheck source=.chore/update.sh
source "${UDB_ROOT}/bin/.chore/update.sh"

#
# Generate .github/workflows/regress.yml
# Returns: 0 on success, 1 if file changed (when fail_on_change=1)
#
do_gen_regress() {
  echo "Generating .github/workflows/regress.yml"
  if [ $fail_on_change -eq 1 ]; then
    local sha_before
    sha_before=$(sha256sum "$UDB_ROOT"/.github/workflows/regress.yml)
  fi
  rm -f .github/workflows/regress.yml
  "$UDB_ROOT/bin/bundle" exec ruby tools/test/gen_regress.rb
  chmod -wx .github/workflows/regress.yml
  if [ $fail_on_change -eq 1 ]; then
    local sha_after
    sha_after=$(sha256sum "$UDB_ROOT"/.github/workflows/regress.yml)
    if [ "$sha_before" != "$sha_after" ]; then
      exit 1
    fi
  fi
}

#
# Generate the IDL TextMate grammar for the VSCode extension from
# the canonical Prism definition at doc/src/prism/idl.js
#
do_gen_vscode_idl() {
  local out="$UDB_ROOT/tools/vscode/idl/syntaxes/idl.tmLanguage.json"
  echo "Generating tools/vscode/idl/syntaxes/idl.tmLanguage.json"
  if [ $fail_on_change -eq 1 ]; then
    local sha_before
    sha_before=$(sha256sum "$out")
  fi
  node "$UDB_ROOT/tools/node/idl-grammar-gen/index.js"
  if [ $fail_on_change -eq 1 ]; then
    local sha_after
    sha_after=$(sha256sum "$out")
    if [ "$sha_before" != "$sha_after" ]; then
      exit 1
    fi
  fi
}

#
# Generate schema documentation from JSON Schema files
#
do_gen_schema_docs() {
  echo "Generating schema documentation"
  if [ $fail_on_change -eq 1 ]; then
    # Calculate checksum before generation
    local sha_before
    sha_before=$(find "$UDB_ROOT"/doc/docs/schemas -type f -name "*.mdx" -exec sha256sum {} \; 2>/dev/null | sort | sha256sum)
  fi
  "$UDB_ROOT/bin/ruby" "$UDB_ROOT/tools/internal-gems/schema_doc_gen/bin/schema-docs-all" \
    --schema-dir "$UDB_ROOT/spec/schemas" \
    --output-dir "$UDB_ROOT/doc/docs/schemas" \
    --generate-index
  if [ $fail_on_change -eq 1 ]; then
    local sha_after
    sha_after=$(find "$UDB_ROOT"/doc/docs/schemas -type f -name "*.mdx" -exec sha256sum {} \; 2>/dev/null | sort | sha256sum)
    if [ "$sha_before" != "$sha_after" ]; then
      exit 1
    fi
  fi
}

#
# Sync inter-gem version pins in gemspecs and Gemfile.lock files for the
# locally-developed gems in tools/ruby-gems/.
# Returns: 0 on success, 1 if files changed (when fail_on_change=1)
#
do_gen_gem_versions() {
  local extra_args=()
  if [ -n "$1" ]; then
    extra_args=(--base-ref "$1")
  fi
  echo "Syncing inter-gem version pins for tools/ruby-gems/ gems"
  if [ $fail_on_change -eq 1 ]; then
    "$UDB_ROOT/bin/ruby" "$UDB_ROOT"/tools/scripts/gen_gem_versions.rb --fail-on-change "${extra_args[@]}"
  else
    "$UDB_ROOT/bin/ruby" "$UDB_ROOT"/tools/scripts/gen_gem_versions.rb "${extra_args[@]}"
  fi
}

# Auto-increment versions for gems with source changes (with cascade),
# then sync inter-gem version pins in gemspecs and Gemfile.lock.
# Args: $1 - base ref (optional; defaults to origin/main)
# Returns: 0 on success
#
do_update_gem_versions() {
  local extra_args=()
  if [ -n "$1" ]; then
    extra_args=(--base-ref "$1")
  fi
  echo "Bumping versions and syncing inter-gem pins for tools/ruby-gems/ gems"
  "$UDB_ROOT/bin/ruby" "$UDB_ROOT"/tools/scripts/gen_gem_versions.rb --auto-bump "${extra_args[@]}"
}

#
# Generate all development artifacts
#
do_gen_all() {
  do_gen_regress
  do_gen_vscode_idl
  do_gen_gem_versions
  do_ruby_type_def all
  do_gen_profile_cfgs
  do_gen_xqci_golden
  do_gen_schema_docs
  do_gen_cfg_headers_golden
}

#
# Generate the development artifacts that are quick to resolve; should be run frequently (e.g., before git push)
#
do_gen_smoke() {
  do_gen_regress
  do_gen_vscode_idl
  do_ruby_type_def all
}

#
# Generate strict config files for profiles (cfgs/profile/)
# Returns: 0 on success, 1 if files changed (when fail_on_change=1)
#
do_gen_profile_cfgs() {
  echo "Generating profile config files in cfgs/profile/"
  local cfgs_dir="${UDB_ROOT}/cfgs/profile"

  # Capture the state before generation
  local before_hash=""
  if [ -d "$cfgs_dir" ]; then
    before_hash=$(find "$cfgs_dir" -type f -name "*.yaml" -exec md5sum {} \; | sort | md5sum | awk '{print $1}')
  fi

  "${UDB_ROOT}"/bin/bundle exec rake gen:cfg

  if [ $fail_on_change -eq 1 ]; then
    local after_hash=""
    if [ -d "$cfgs_dir" ]; then
      after_hash=$(find "$cfgs_dir" -type f -name "*.yaml" -exec md5sum {} \; | sort | md5sum | awk '{print $1}')
    fi

    if [ "$before_hash" != "$after_hash" ]; then
      echo "[ERROR]: Profile config files changed during generation"
      return 1
    fi
  fi
  return 0
}

#
# Generate Xqci golden adoc file
#
do_gen_xqci_golden() {
  echo "Generating Xqci golden adoc"
  local xqci_version
  xqci_version=$("${UDB_ROOT}"/bin/bundle exec ruby -e "require 'yaml'; puts YAML.load_file('spec/custom/isa/qc_iu/ext/Xqci.yaml')['versions'].last['version']" | tr -d '\r\n')
  "${UDB_ROOT}"/bin/bundle exec ruby tools/scripts/gen_xqci.rb
  mkdir -p tests/data/golden
  # Remove any stale golden files from previous versions
  rm -f tests/data/golden/Xqci@*.adoc
  cp "gen/ext-doc/pdf/Xqci-${xqci_version}.pdf/Xqci@${xqci_version}.adoc" \
     "tests/data/golden/Xqci@${xqci_version}.adoc"
  # Remove the commit info line from the golden file
  sed -i '/^This document was created using the http:\/\/github\.org\/riscv\/riscv-unified-db\[RISC-V Unified Database\] at commit/d' \
    "tests/data/golden/Xqci@${xqci_version}.adoc"
}

#
# Generate golden cfg header files (C and SystemVerilog) for regression testing
# Returns: 0 on success, 1 if files changed (when fail_on_change=1)
#
do_gen_cfg_headers_golden() {
  echo "Generating golden cfg header files"
  local cfg="mc100-32-full-example"
  local gen_dir="${UDB_ROOT}/gen/cfg_headers"
  local golden_dir="${UDB_ROOT}/tests/golden"

  # Capture the state before generation
  local before_hash=""
  if [ -d "$golden_dir" ]; then
    before_hash=$(find "$golden_dir" -type f \( -name "${cfg}.golden.h" -o -name "${cfg}.golden.svh" \) -exec md5sum {} \; | sort | md5sum | awk '{print $1}')
  fi

  mkdir -p "$gen_dir" "$golden_dir"
  "${UDB_ROOT}"/bin/bundle exec udb-gen cfg-c-header -c "$cfg" -o "${gen_dir}/${cfg}.h"
  "${UDB_ROOT}"/bin/bundle exec udb-gen cfg-svh-header -c "$cfg" -o "${gen_dir}/${cfg}.svh"
  cp "${gen_dir}/${cfg}.h" "${golden_dir}/${cfg}.golden.h"
  cp "${gen_dir}/${cfg}.svh" "${golden_dir}/${cfg}.golden.svh"

  if [ $fail_on_change -eq 1 ]; then
    local after_hash=""
    if [ -d "$golden_dir" ]; then
      after_hash=$(find "$golden_dir" -type f \( -name "${cfg}.golden.h" -o -name "${cfg}.golden.svh" \) -exec md5sum {} \; | sort | md5sum | awk '{print $1}')
    fi

    if [ "$before_hash" != "$after_hash" ]; then
      echo "[ERROR]: Golden cfg header files changed during generation"
      return 1
    fi
  fi
  return 0
}

#
# Install new Ruby gems
# Returns: 0 on success, exits with 1 on error
#
do_install_gems() {
  do_lock_all_gemfiles

  "${UDB_ROOT}"/bin/bundle install
  do_ruby_type_def
}

#
# Generate Ruby type definitions (Sorbet RBI files)
# Returns: 0 on success, exits with 1 on error
#
do_ruby_type_def() {
  cd "${UDB_ROOT}" || exit 1
  "${UDB_ROOT}"/bin/bundle exec --gemfile "${UDB_ROOT}"/Gemfile tapioca gems --all
  "${UDB_ROOT}"/bin/bundle exec --gemfile "${UDB_ROOT}"/Gemfile tapioca dsl

  # tapioca annotations requires the ext/rbi-central submodule to be initialized.
  if [ ! -f "${UDB_ROOT}/ext/rbi-central/index.json" ]; then
    echo "Initializing ext/rbi-central submodule..."
    git -C "${UDB_ROOT}" submodule update --init ext/rbi-central
  fi
  "${UDB_ROOT}"/bin/bundle exec --gemfile "${UDB_ROOT}"/Gemfile tapioca annotations
}

#
# Build the udb gem
# Args: $1 - gen_dir (optional override for staging directory; empty string = use default)
# Returns: 0 on success, exits with 1 on error
#
do_build_udb_gem() {
  local gen_dir=$1

  local staging_dir="${gen_dir:-${UDB_ROOT}/gen/udb_gem}"

  echo "Preparing udb gem staging directory at ${staging_dir} and building gem..."
  local rake_env=""
  if [ -n "$gen_dir" ]; then
    rake_env="UDB_GEM_GEN_DIR=${gen_dir} "
  fi
  # Run prepare and gem build in a single invocation so that the
  # staging directory (which may be outside the repo-root mount) is accessible
  # to both steps.
  local build_cmd
  build_cmd=$(cat << CMD
cd ${UDB_ROOT}/tools/ruby-gems/udb && \
${rake_env}${UDB_ROOT}/bin/bundle exec --gemfile ${UDB_ROOT}/Gemfile rake release:udb:prepare && \
cd ${staging_dir} && \
BUNDLE_GEMFILE= ${UDB_ROOT}/bin/gem build udb.gemspec
CMD
  )
  bash -c "$build_cmd" || exit $?

  # Announce the location of the built gem (path is the same on host when
  # staging_dir is inside the repo root; otherwise just print the directory).
  local gem_file
  gem_file=$(ls "${staging_dir}"/udb-*.gem 2>/dev/null | sort -V | tail -1)
  if [ -n "$gem_file" ]; then
    echo "udb gem built successfully: ${gem_file}"
  else
    echo "udb gem built in: ${staging_dir}"
  fi
}

while getopts ":h" opt; do # Go through the options
  case $opt in
    # help
    h )
      help
      exit 0 # Exit correctly
    ;;
    # Invalid option
    ? )
        echo "[ERROR]: Invalid option: -${OPTARG}"
        help
        exit 1 # Exit with error
    ;;
  esac
done
shift $((OPTIND-1))
subcommand=$1; shift # Get subcommand and shift to next option

case "$subcommand" in
  container )
    while getopts ":h" opt; do
      case $opt in
        h )
          container_subcmd_usage
          exit 0
        ;;
        ? )
          echo "[ERROR]: Invalid option: -${OPTARG}"
          container_subcmd_usage
          exit 1
        ;;
      esac
    done
    shift $((OPTIND-1))
    OPTIND=1  # Reset OPTIND for inner getopts loops
    target="$1"; shift
    case "$target" in
      build )
        force=no
        while getopts ":hf" opt; do
          case $opt in
            h ) container_build_usage; exit 0 ;;
            f ) force=yes ;;
            ? ) echo "[ERROR]: Invalid option: -${OPTARG}"; container_build_usage; exit 1 ;;
          esac
        done
        do_container_build "$force"
        exit 0
      ;;
      pull )
        force=no
        while getopts ":hf" opt; do
          case $opt in
            h ) container_pull_usage; exit 0 ;;
            f ) force=yes ;;
            ? ) echo "[ERROR]: Invalid option: -${OPTARG}"; container_pull_usage; exit 1 ;;
          esac
        done
        do_container_pull "$force"
        exit 0
      ;;
      remove|rm )
        while getopts ":h" opt; do
          case $opt in
            h ) container_remove_usage; exit 0 ;;
            ? ) echo "[ERROR]: Invalid option: -${OPTARG}"; container_remove_usage; exit 1 ;;
          esac
        done
        do_container_remove
        exit 0
      ;;
      * )
        echo "Invalid target: $target"
        container_subcmd_usage
        exit 1
    esac
    ;;
  gen )
    fail_on_change=0
    base_ref=""
    while getopts ":hfb:" opt; do # Go through the options
      case $opt in
        # help
        h )
          gen_subcmd_usage
          exit 0 # Exit correctly
        ;;
        f )
          fail_on_change=1
          shift
          ;;
        b )
          base_ref="$OPTARG"
          shift
          shift
          ;;
        # Invalid option
        ? )
            echo "[ERROR]: Invalid option: -${OPTARG}"
            gen_subcmd_usage
            exit 1 # Exit with error
        ;;
      esac
    done
    target="$1"; shift
    case "$target" in
      all )
        do_gen_all
        exit 0
        ;;
      smoke )
        do_gen_smoke
        exit 0
        ;;
      gem-versions )
        do_gen_gem_versions "$base_ref"
        exit 0
        ;;
      vscode-idl )
        do_gen_vscode_idl
        exit 0
        ;;
      regress )
        do_gen_regress
        exit 0
        ;;
      schema-docs )
        do_gen_schema_docs
        exit 0
        ;;
      profile-cfgs )
        do_gen_profile_cfgs
        exit_code=$?
        exit $exit_code
        ;;
      xqci )
        do_gen_xqci_golden
        exit 0
        ;;
      cfg-headers )
        do_gen_cfg_headers_golden
        exit_code=$?
        exit $exit_code
        ;;
      ruby-type-def )
        while getopts ":h" opt; do # Go through the options
          case $opt in
            # help
            h )
              gen_ruby_type_def_usage
              exit 0 # Exit correctly
            ;;
            # Invalid option
            ? )
                echo "[ERROR]: Invalid option: -${OPTARG}"
                gen_ruby_type_def_usage
                exit 1 # Exit with error
            ;;
          esac
        done
        shift $((OPTIND - 1))
        if [[ $# -gt 0 ]]; then
            echo "Unexpected argument remaining: $*" >&2
            gen_ruby_type_def_usage
            exit 1
        fi
        do_ruby_type_def
        exit 0
        ;;
      * )
        echo "Invalid target: $subcommand"
        gen_subcmd_usage
        exit 1
    esac
    ;;
  install )
    while getopts ":h" opt; do
      case $opt in
        # help
        h )
          install_subcmd_usage
          exit 0
        ;;
        ? )
          echo "[ERROR]: Invalid option: -${OPTARG}"
          install_subcmd_usage
          exit 1 # Exit with error
        ;;
      esac
    done
    target="$1"; shift
    case "$target" in
      gems )
        while getopts ":h" opt; do
          case $opt in
            # help
            h )
              install_gems_usage
              exit 0
            ;;
            ? )
              echo "[ERROR]: Invalid option: -${OPTARG}"
              install_gems_usage
              exit 1 # Exit with error
            ;;
          esac
        done
        do_install_gems
        exit 0
      ;;
      * )
        echo "Invalid target: $subcommand"
        install_subcmd_usage
        exit 1
    esac
    ;;
  update )
    while getopts ":h" opt; do # Go through the options
      case $opt in
        # help
        h )
          update_subcmd_usage
          exit 0 # Exit correctly
        ;;
        # Invalid option
        ? )
            echo "[ERROR]: Invalid option: -${OPTARG}"
            update_subcmd_usage
            exit 1 # Exit with error
        ;;
      esac
    done
    target="$1"; shift
    case "$target" in
      gem-versions )
        base_ref=""
        while getopts ":hb:" opt; do
          case $opt in
            h )
              update_gem_versions_usage
              exit 0
              ;;
            b )
              base_ref="$OPTARG"
              ;;
            ? )
              echo "[ERROR]: Invalid option: -${OPTARG}"
              update_gem_versions_usage
              exit 1
              ;;
          esac
        done
        do_update_gem_versions "$base_ref"
        exit 0
        ;;
      gems )
          while getopts ":h" opt; do # Go through the options
            case $opt in
              # help
              h )
                update_gems_usage
                exit 0 # Exit correctly
              ;;
              # Invalid option
              ? )
                  echo "[ERROR]: Invalid option: -${OPTARG}"
                  update_gems_usage
                  exit 1 # Exit with error
              ;;
            esac
          done
        do_update_gems
        exit 0
      ;;
      eqntott )
        native_only=no
        force=no
        while getopts ":hnf" opt; do
          case $opt in
            h )
              update_eqntott_usage
              exit 0
              ;;
            n )
              native_only=yes
              ;;
            f )
              force=yes
              ;;
            ? )
              echo "[ERROR]: Invalid option: -${OPTARG}"
              update_eqntott_usage
              exit 1
              ;;
          esac
        done
        do_update_eqntott "$native_only" "$force"
        exit 0
        ;;
      espresso )
        native_only=no
        force=no
        while getopts ":hnf" opt; do
          case $opt in
            h )
              update_espresso_usage
              exit 0
              ;;
            n )
              native_only=yes
              ;;
            f )
              force=yes
              ;;
            ? )
              echo "[ERROR]: Invalid option: -${OPTARG}"
              update_espresso_usage
              exit 1
              ;;
          esac
        done
        do_update_espresso "$native_only" "$force"
        exit 0
        ;;
      must )
        native_only=no
        force=no
        while getopts ":hnf" opt; do
          case $opt in
            h )
              update_must_usage
              exit 0
              ;;
            n )
              native_only=yes
              ;;
            f )
              force=yes
              ;;
            ? )
              echo "[ERROR]: Invalid option: -${OPTARG}"
              update_must_usage
              exit 1
              ;;
          esac
        done
        do_update_must "$native_only" "$force"
        exit 0
        ;;
      z3 )
        native_only=no
        force=no
        while getopts ":hnf" opt; do
          case $opt in
            h )
              update_z3_usage
              exit 0
              ;;
            n )
              native_only=yes
              ;;
            f )
              force=yes
              ;;
            ? )
              echo "[ERROR]: Invalid option: -${OPTARG}"
              update_z3_usage
              exit 1
              ;;
          esac
        done
        do_update_z3 "$native_only" "$force"
        exit 0
        ;;
      * )
        echo "Invalid target: $subcommand"
        update_subcmd_usage
        exit 1
    esac
    ;;
  build )
    while getopts ":h" opt; do
      case $opt in
        h )
          build_subcmd_usage
          exit 0
        ;;
        ? )
          echo "[ERROR]: Invalid option: -${OPTARG}"
          build_subcmd_usage
          exit 1
        ;;
      esac
    done
    target="$1"; shift
    case "$target" in
      udb-gem )
        gen_dir=""
        while getopts ":hd:" opt; do
          case $opt in
            h )
              build_udb_gem_usage
              exit 0
            ;;
            d )
              gen_dir=$OPTARG
            ;;
            ? )
              echo "[ERROR]: Invalid option: -${OPTARG}"
              build_udb_gem_usage
              exit 1
            ;;
          esac
        done
        do_build_udb_gem "$gen_dir"
        exit 0
      ;;
      * )
        echo "Invalid target: $target"
        build_subcmd_usage
        exit 1
    esac
    ;;
  * )
    if [ ! -z "$subcommand" ]; then  # Don't show if no subcommand provided
      echo "Invalid subcommand: $subcommand"
    fi
    help
    exit 1 # Exit with error
  ;;
esac
