#
# Generate .github/workflows/regress.yml
# Returns: 0 on success, 1 if file changed (when fail_on_change=1)
#
do_gen_regress() {
  source_setup
  echo "Generating .github/workflows/regress.yml"
  if [ $fail_on_change -eq 1 ]; then
    local sha_before
    sha_before=$(sha256sum "$UDB_ROOT"/.github/workflows/regress.yml)
  fi
  rm -f .github/workflows/regress.yml
  $RUBY tools/test/gen_regress.rb
  chmod -wx .github/workflows/regress.yml
  if [ $fail_on_change -eq 1 ]; then
    local sha_after
    sha_after=$(sha256sum "$UDB_ROOT"/.github/workflows/regress.yml)
    if [ "$sha_before" != "$sha_after" ]; then
      exit 1
    fi
  fi
}

#
# Generate the IDL TextMate grammar for the VSCode extension from
# the canonical Prism definition at doc/src/prism/idl.js
#
do_gen_vscode_idl() {
  local out="$UDB_ROOT/tools/vscode/idl/syntaxes/idl.tmLanguage.json"
  echo "Generating tools/vscode/idl/syntaxes/idl.tmLanguage.json"
  if [ $fail_on_change -eq 1 ]; then
    local sha_before
    sha_before=$(sha256sum "$out")
  fi
  node "$UDB_ROOT/tools/node/idl-grammar-gen/index.js"
  if [ $fail_on_change -eq 1 ]; then
    local sha_after
    sha_after=$(sha256sum "$out")
    if [ "$sha_before" != "$sha_after" ]; then
      exit 1
    fi
  fi
}

#
# Lock all Gemfiles with consistent platforms.
#
# The root Gemfile is a union of all per-gem gemspecs and is used as the
# authoritative dependency resolution context. It must be locked first so that
# when Bundler locks each per-gem Gemfile (which runs under `bundle exec` from
# the root context), it resolves transitive dependencies (e.g. activesupport,
# sorbet) to the same versions as the root. If the per-gem locks ran first,
# they could resolve to different versions and diverge from the root, causing
# failures in tools like sorbet that compare the installed gem version against
# committed RBI files.
#
# Args: extra args to pass to each `bundle lock` call (e.g. --update --bundler)
#
do_lock_all_gemfiles() {
  # Always include both x86_64 and aarch64 Linux platforms so lock files are
  # valid on both architectures.
  local platforms="--add-platform x86_64-linux --add-platform x86_64-linux-gnu --add-platform aarch64-linux --add-platform aarch64-linux-gnu"
  # Root first — per-gem locks must be derived from this resolved graph.
  #
  # BUNDLE_GEMFILE must be set to match --gemfile for each call so that
  # Bundler writes PATH remote: entries relative to the correct directory.
  # `env` is used to set BUNDLE_GEMFILE inline so it is passed into the
  # container when $RUN is a docker/podman invocation.
  # Note: `bundle lock` (not `bundle exec bundle lock`) is used deliberately —
  # `bundle exec` requires an existing lockfile to activate the bundle first,
  # which breaks when lockfiles are missing or being regenerated from scratch.
  $RUN env BUNDLE_GEMFILE="${UDB_ROOT}"/Gemfile bundle lock $platforms "$@" --gemfile "${UDB_ROOT}"/Gemfile
  $RUN env BUNDLE_GEMFILE="${UDB_ROOT}"/tools/ruby-gems/idlc/Gemfile bundle lock $platforms "$@" --gemfile "${UDB_ROOT}"/tools/ruby-gems/idlc/Gemfile
  $RUN env BUNDLE_GEMFILE="${UDB_ROOT}"/tools/ruby-gems/udb/Gemfile bundle lock $platforms "$@" --gemfile "${UDB_ROOT}"/tools/ruby-gems/udb/Gemfile
  $RUN env BUNDLE_GEMFILE="${UDB_ROOT}"/tools/ruby-gems/udb-gen/Gemfile bundle lock $platforms "$@" --gemfile "${UDB_ROOT}"/tools/ruby-gems/udb-gen/Gemfile
  $RUN env BUNDLE_GEMFILE="${UDB_ROOT}"/tools/ruby-gems/udb_helpers/Gemfile bundle lock $platforms "$@" --gemfile "${UDB_ROOT}"/tools/ruby-gems/udb_helpers/Gemfile
}

#
# Sync inter-gem version pins in gemspecs and Gemfile.lock files for the
# locally-developed gems in tools/ruby-gems/. Also auto-increments versions
# for any gem whose source changed without a bump (with cascade).
# Returns: 0 on success, 1 if files changed (when fail_on_change=1)
#
do_gen_gem_versions() {
  local extra_args=()
  if [ -n "$1" ]; then
    extra_args=(--base-ref "$1")
  fi
  source_setup
  echo "Syncing inter-gem version pins for tools/ruby-gems/ gems"
  if [ $fail_on_change -eq 1 ]; then
    $RUBY "$UDB_ROOT"/tools/scripts/gen_gem_versions.rb --fail-on-change "${extra_args[@]}"
  else
    $RUBY "$UDB_ROOT"/tools/scripts/gen_gem_versions.rb "${extra_args[@]}"
  fi
}

#
# Generate all development artifacts
#
do_gen_all() {
  do_gen_regress
  do_gen_vscode_idl
  do_gen_gem_versions
  do_ruby_type_def all
  do_gen_xqci_golden
}

#
# Generate the development artifacts that are quick to resolve; should be run frequently (e.g., before git push)
#
do_gen_smoke() {
  do_gen_regress
  do_gen_vscode_idl
  do_ruby_type_def all
}

#
# Generate Xqci golden adoc file
#
do_gen_xqci_golden() {
  source_setup
  echo "Generating Xqci golden adoc"
  local xqci_version
  xqci_version=$($RUBY -e "require 'yaml'; puts YAML.load_file('spec/custom/isa/qc_iu/ext/Xqci.yaml')['versions'].last['version']" | tr -d '\r\n')
  $RUBY tools/scripts/gen_xqci.rb
  mkdir -p tests/data/golden
  # Remove any stale golden files from previous versions
  rm -f tests/data/golden/Xqci@*.adoc
  cp "gen/ext-doc/pdf/Xqci-${xqci_version}.pdf/Xqci@${xqci_version}.adoc" \
     "tests/data/golden/Xqci@${xqci_version}.adoc"
  # Remove the commit info line from the golden file
  sed -i '/^This document was created using the http:\/\/github\.org\/riscv\/riscv-unified-db\[RISC-V Unified Database\] at commit/d' \
    "tests/data/golden/Xqci@${xqci_version}.adoc"
}

#
# Install new Ruby gems and optionally update container tag
# Args: $1 - update_tag ("yes" to increment container tag, "no" otherwise)
# Returns: 0 on success, exits with 1 on error
#
do_install_gems() {
  local update_tag=$1
  source "$UDB_ROOT"/bin/setup

  do_lock_all_gemfiles

  # increment container-tag
  if [ "$update_tag" == "yes" ]; then
    new_version=$(increment_minor_version "$(cat bin/.container-tag)")
    echo "$new_version" > bin/.container-tag
  fi

  if [ "$CONTAINER_TYPE" == "native" ]; then
    bundle install
    do_ruby_type_def idlc
    do_ruby_type_def udb
    do_ruby_type_def udb-gen
  else
    build_container "${UDB_ROOT}"

    # need to run as a seperate process to pick up the new container
    # since we bumped the container tag, this will also cause the container to rebuild
    ./bin/chore gen ruby-type-def
  fi
}

#
# Generate Ruby type definitions (Sorbet RBI files)
# Args: $1 - gem name ("all", "udb", "idlc", or "udb-gen")
# Returns: 0 on success, exits with 1 on error
#
do_ruby_type_def() {
  gem=$1

  source "$UDB_ROOT"/bin/setup


  gems=()
  case "$gem" in
    all )
      gems=("udb" "idlc" "udb-gen")
      ;;
    udb )
      gems=("udb")
      ;;
    idlc )
      gems=("idlc")
      ;;
    udb-gen )
      gems=("udb-gen")
      ;;
    * )
      echo "Invalid gem '$gem'" >&2
      echo "Options are: [all, udb, idlc, udb-gen]" >&2
      exit 1 # Exit with error
      ;;
  esac
  # Background jobs are not a TTY; strip -it from RUN to avoid docker complaints.
  local RUN_NO_TTY="${RUN//-it /}"

  # Run tapioca gems+dsl for each gem in parallel (writes are per-gem).
  local pids=()
  for gem in "${gems[@]}"; do
    gem_gemfile="${UDB_ROOT}/tools/ruby-gems/${gem}/Gemfile"
    steps=$(cat << STEPS
      cd ${UDB_ROOT}/tools/ruby-gems/${gem} && \
      BUNDLE_GEMFILE=${gem_gemfile} bundle exec tapioca gems --all && \
      BUNDLE_GEMFILE=${gem_gemfile} bundle exec tapioca dsl
STEPS
    )
    $RUN_NO_TTY /bin/bash -c "$steps" &
    pids+=($!)
  done

  local rc=0
  for pid in "${pids[@]}"; do
    wait "$pid" || rc=$?
  done
  [ $rc -ne 0 ] && exit $rc

  # Run tapioca annotations sequentially to avoid races on the shared gem cache.
  for gem in "${gems[@]}"; do
    gem_gemfile="${UDB_ROOT}/tools/ruby-gems/${gem}/Gemfile"
    $RUN_NO_TTY /bin/bash -c "cd ${UDB_ROOT}/tools/ruby-gems/${gem} && BUNDLE_GEMFILE=${gem_gemfile} bundle exec tapioca annotations" || exit $?
  done
}

#
# Build the udb gem
# Args: $1 - gen_dir (optional override for staging directory; empty string = use default)
# Returns: 0 on success, exits with 1 on error
#
do_build_udb_gem() {
  local gen_dir=$1
  source_setup

  local staging_dir="${gen_dir:-${UDB_ROOT}/gen/udb_gem}"

  echo "Preparing udb gem staging directory at ${staging_dir} and building gem..."
  local rake_env=""
  if [ -n "$gen_dir" ]; then
    rake_env="UDB_GEM_GEN_DIR=${gen_dir} "
  fi
  # Run prepare and gem build in a single container invocation so that the
  # staging directory (which may be outside the repo-root mount) is accessible
  # to both steps.
  local build_cmd
  build_cmd=$(cat << CMD
cd ${UDB_ROOT}/tools/ruby-gems/udb && \
${rake_env}bundle exec rake release:udb:prepare && \
cd ${staging_dir} && \
BUNDLE_GEMFILE= gem build udb.gemspec
CMD
  )
  $RUN /bin/bash -c "$build_cmd" || exit $?

  # Announce the location of the built gem (path is the same on host when
  # staging_dir is inside the repo root; otherwise just print the directory).
  local gem_file
  gem_file=$(ls "${staging_dir}"/udb-*.gem 2>/dev/null | sort -V | tail -1)
  if [ -n "$gem_file" ]; then
    echo "udb gem built successfully: ${gem_file}"
  else
    echo "udb gem built in: ${staging_dir}"
  fi
}

while getopts ":h" opt; do # Go through the options
  case $opt in
    # help
    h )
      help
      exit 0 # Exit correctly
    ;;
    # Invalid option
    ? )
        echo "[ERROR]: Invalid option: -${OPTARG}"
        help
        exit 1 # Exit with error
    ;;
  esac
done
shift $((OPTIND-1))
subcommand=$1; shift # Get subcommand and shift to next option

case "$subcommand" in
  container )
    while getopts ":h" opt; do
      case $opt in
        # help
        h )
          container_subcmd_usage
          exit 0
        ;;
        ? )
          echo "[ERROR]: Invalid option: -${OPTARG}"
          container_subcmd_usage
          exit 1 # Exit with error
        ;;
      esac
    done
    target="$1"; shift
    case "$target" in
      build )
        force=no
        while getopts ":hf" opt; do
          case $opt in
            # help
            h )
              container_build_usage
              exit 0
            ;;
            f )
              force=yes
              ;;
            ? )
              echo "[ERROR]: Invalid option: -${OPTARG}"
              container_build_usage
              exit 1 # Exit with error
            ;;
          esac
        done
        do_container_build "$force"
        exit 0
      ;;
      pull )
        force=no
        while getopts ":hf" opt; do
          case $opt in
            # help
            h )
              container_pull_usage
              exit 0
            ;;
            f )
              force=yes
              ;;
            ? )
              echo "[ERROR]: Invalid option: -${OPTARG}"
              container_pull_usage
              exit 1 # Exit with error
            ;;
          esac
        done
        do_container_pull "$force"
        exit 0
      ;;
      remove|rm )
        while getopts ":h" opt; do
          case $opt in
            # help
            h )
              container_remove_usage
              exit 0
            ;;
            ? )
              echo "[ERROR]: Invalid option: -${OPTARG}"
              container_remove_usage
              exit 1 # Exit with error
            ;;
          esac
        done
        do_container_remove
        exit 0
      ;;
      * )
        echo "Invalid target: $target"
        container_subcmd_usage
        exit 1
    esac
    ;;
  gen )
    fail_on_change=0
    base_ref=""
    while getopts ":hfb:" opt; do # Go through the options
      case $opt in
        # help
        h )
          gen_subcmd_usage
          exit 0 # Exit correctly
        ;;
        f )
          fail_on_change=1
          shift
          ;;
        b )
          base_ref="$OPTARG"
          shift
          shift
          ;;
        # Invalid option
        ? )
            echo "[ERROR]: Invalid option: -${OPTARG}"
            gen_subcmd_usage
            exit 1 # Exit with error
        ;;
      esac
    done
    target="$1"; shift
    case "$target" in
      all )
        do_gen_all
        exit 0
        ;;
      smoke )
        do_gen_smoke
        exit 0
        ;;
      gem-versions )
        do_gen_gem_versions "$base_ref"
        exit 0
        ;;
      vscode-idl )
        do_gen_vscode_idl
        exit 0
        ;;
      regress )
        do_gen_regress
        exit 0
        ;;
      xqci )
        do_gen_xqci_golden
        exit 0
        ;;
      ruby-type-def )
        gem=all
        while getopts ":hg:" opt; do # Go through the options
          case $opt in
            # help
            h )
              gen_ruby_type_def_usage
              exit 0 # Exit correctly
            ;;
            g )
              gem=$OPTARG
              shift
              ;;
            # Invalid option
            ? )
                echo "[ERROR]: Invalid option: -${OPTARG}"
                gen_ruby_type_def_usage
                exit 1 # Exit with error
            ;;
          esac
        done
        shift $((OPTIND - 1))
        if [[ $# -gt 0 ]]; then
            echo "Unexpected argument remaining: $*" >&2
            gen_ruby_type_def_usage
            exit 1
        fi
        do_ruby_type_def "$gem"
        exit 0
        ;;
      * )
        echo "Invalid target: $subcommand"
        gen_subcmd_usage
        exit 1
    esac
    ;;
  install )
    while getopts ":h" opt; do
      case $opt in
        # help
        h )
          install_subcmd_usage
          exit 0
        ;;
        t )
          update_tag=no
          ;;
        ? )
          echo "[ERROR]: Invalid option: -${OPTARG}"
          install_subcmd_usage
          exit 1 # Exit with error
        ;;
      esac
    done
    target="$1"; shift
    case "$target" in
      gems )
        update_tag=yes
        while getopts ":ht" opt; do
          case $opt in
            # help
            h )
              install_gems_usage
              exit 0
            ;;
            t )
              update_tag=no
              ;;
            ? )
              echo "[ERROR]: Invalid option: -${OPTARG}"
              install_gems_usage
              exit 1 # Exit with error
            ;;
          esac
        done
        do_install_gems "$update_tag"
        exit 0
      ;;
      * )
        echo "Invalid target: $subcommand"
        install_subcmd_usage
        exit 1
    esac
    ;;
  update )
    while getopts ":h" opt; do # Go through the options
      case $opt in
        # help
        h )
          update_subcmd_usage
          exit 0 # Exit correctly
        ;;
        # Invalid option
        ? )
            echo "[ERROR]: Invalid option: -${OPTARG}"
            update_subcmd_usage
            exit 1 # Exit with error
        ;;
      esac
    done
    target="$1"; shift
    case "$target" in
      gems )
          update_tag=yes
          while getopts ":ht" opt; do # Go through the options
            case $opt in
              # help
              h )
                update_gems_usage
                exit 0 # Exit correctly
              ;;
              t )
                update_tag=no
              ;;
              # Invalid option
              ? )
                  echo "[ERROR]: Invalid option: -${OPTARG}"
                  update_gems_usage
                  exit 1 # Exit with error
              ;;
            esac
          done
        do_update_gems "$update_tag"
        exit 0
      ;;
      eqntott )
        native_only=no
        force=no
        while getopts ":hnf" opt; do
          case $opt in
            h )
              update_eqntott_usage
              exit 0
              ;;
            n )
              native_only=yes
              ;;
            f )
              force=yes
              ;;
            ? )
              echo "[ERROR]: Invalid option: -${OPTARG}"
              update_eqntott_usage
              exit 1
              ;;
          esac
        done
        do_update_eqntott "$native_only" "$force"
        exit 0
        ;;
      espresso )
        native_only=no
        force=no
        while getopts ":hnf" opt; do
          case $opt in
            h )
              update_espresso_usage
              exit 0
              ;;
            n )
              native_only=yes
              ;;
            f )
              force=yes
              ;;
            ? )
              echo "[ERROR]: Invalid option: -${OPTARG}"
              update_espresso_usage
              exit 1
              ;;
          esac
        done
        do_update_espresso "$native_only" "$force"
        exit 0
        ;;
      must )
        native_only=no
        force=no
        while getopts ":hnf" opt; do
          case $opt in
            h )
              update_must_usage
              exit 0
              ;;
            n )
              native_only=yes
              ;;
            f )
              force=yes
              ;;
            ? )
              echo "[ERROR]: Invalid option: -${OPTARG}"
              update_must_usage
              exit 1
              ;;
          esac
        done
        do_update_must "$native_only" "$force"
        exit 0
        ;;
      z3 )
        native_only=no
        force=no
        while getopts ":hnf" opt; do
          case $opt in
            h )
              update_z3_usage
              exit 0
              ;;
            n )
              native_only=yes
              ;;
            f )
              force=yes
              ;;
            ? )
              echo "[ERROR]: Invalid option: -${OPTARG}"
              update_z3_usage
              exit 1
              ;;
          esac
        done
        do_update_z3 "$native_only" "$force"
        exit 0
        ;;
      * )
        echo "Invalid target: $subcommand"
        update_subcmd_usage
        exit 1
    esac
    ;;
  build )
    while getopts ":h" opt; do
      case $opt in
        h )
          build_subcmd_usage
          exit 0
        ;;
        ? )
          echo "[ERROR]: Invalid option: -${OPTARG}"
          build_subcmd_usage
          exit 1
        ;;
      esac
    done
    target="$1"; shift
    case "$target" in
      udb-gem )
        gen_dir=""
        while getopts ":hd:" opt; do
          case $opt in
            h )
              build_udb_gem_usage
              exit 0
            ;;
            d )
              gen_dir=$OPTARG
            ;;
            ? )
              echo "[ERROR]: Invalid option: -${OPTARG}"
              build_udb_gem_usage
              exit 1
            ;;
          esac
        done
        do_build_udb_gem "$gen_dir"
        exit 0
      ;;
      * )
        echo "Invalid target: $target"
        build_subcmd_usage
        exit 1
    esac
    ;;
  * )
    if [ ! -z "$subcommand" ]; then  # Don't show if no subcommand provided
      echo "Invalid subcommand: $subcommand"
    fi
    help
    exit 1 # Exit with error
  ;;
esac
