#!/usr/bin/env bash
# bin/.venv-deps — install/sync Python packages to a shared, hash-keyed location.
#
# Uses UV_PROJECT_ENVIRONMENT to direct uv sync to a shared venv outside the
# worktree, keyed by uv.lock hash.  Multiple worktrees with the same lockfile
# share a single venv; worktrees at different lockfile versions get independent
# environments and never clobber each other.
#
# Called by bin/setup and by git hooks (post-merge, post-checkout).

ROOT=$(dirname "$(dirname "$(realpath "${BASH_SOURCE[0]}")")")

_VENV_LOCK_HASH=$(sha256sum "$ROOT/uv.lock" | cut -c1-16)
_VENV_SHARED="${XDG_DATA_HOME:-$HOME/.local/share}/udb/venv-$_VENV_LOCK_HASH"

_VENV_MARKER="$_VENV_SHARED/.uv-sync-complete"

if [[ ! -f "$_VENV_MARKER" ]]; then
  echo "uv: syncing packages (venv-$_VENV_LOCK_HASH)..."
  WD=$(pwd)
  cd "$ROOT" || exit 1
  rm -rf "$_VENV_SHARED"
  if ! UV_PROJECT_ENVIRONMENT="$_VENV_SHARED" "$ROOT/bin/uv" sync; then
    echo "ERROR: uv sync failed." >&2
    exit 1
  fi
  touch "$_VENV_MARKER"
  echo "uv: packages installed"
  cd "$WD" || exit 1
else
  echo "uv: packages up to date (venv-$_VENV_LOCK_HASH)"
fi

# Point this worktree's .venv at the shared installation.
_VENV_LINK="$ROOT/.venv"
if [[ "$(readlink "$_VENV_LINK" 2>/dev/null)" != "$_VENV_SHARED" ]]; then
  rm -rf "$_VENV_LINK"
  ln -s "$_VENV_SHARED" "$_VENV_LINK"
fi
