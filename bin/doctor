#!/bin/bash
# bin/doctor — check that the development environment is correctly set up.

ROOT=$(dirname "$(dirname "$(realpath "${BASH_SOURCE[0]}")")")

# Load local toolchain preference (same as ./do)
[ -f "${ROOT}/.toolchain-local" ] && source "${ROOT}/.toolchain-local"

# ---------------------------------------------------------------------------
# Color / formatting helpers
# ---------------------------------------------------------------------------

if [[ -z "${NO_COLOR:-}" ]] && [[ -t 1 ]]; then
  _C_BOLD=$'\033[1m'
  _C_RESET=$'\033[0m'
  _C_GREEN=$'\033[32m'
  _C_RED=$'\033[31m'
  _C_YELLOW=$'\033[33m'
  _C_CYAN=$'\033[36m'
  _C_DIM=$'\033[2m'
else
  _C_BOLD='' _C_RESET='' _C_GREEN='' _C_RED='' _C_YELLOW='' _C_CYAN='' _C_DIM=''
fi

_pass() { printf "  ${_C_BOLD}${_C_GREEN}✓${_C_RESET}  %s\n" "$1"; }
_fail() { printf "  ${_C_BOLD}${_C_RED}✗${_C_RESET}  %s\n" "$1"; }
_warn() { printf "  ${_C_BOLD}${_C_YELLOW}!${_C_RESET}  %s\n" "$1"; }
_info() { printf "     ${_C_DIM}%s${_C_RESET}\n" "$1"; }

_section() {
  printf "\n${_C_BOLD}${_C_CYAN}[%s]${_C_RESET}" "$1"
  if [[ -n "${2:-}" ]]; then
    printf "  ${_C_DIM}%s${_C_RESET}" "$2"
  fi
  printf "\n"
}

_check_native_binary() {
  local name="$1" bin_path="$2"
  if [[ -f "$bin_path" ]]; then
    _pass "$name binary available"
    _record_pass
  else
    _fail "$name binary not downloaded"
    _info "Expected: $bin_path"
    _info "Fix: run \`bin/setup\` to download native dependencies"
    _record_fail
  fi
}

# ---------------------------------------------------------------------------
# Counters
# ---------------------------------------------------------------------------

_PASS_COUNT=0
_FAIL_COUNT=0
_WARN_COUNT=0

_record_pass() { ((_PASS_COUNT++)) || true; }
_record_fail() { ((_FAIL_COUNT++)) || true; }
_record_warn() { ((_WARN_COUNT++)) || true; }

# ---------------------------------------------------------------------------
# Section 1: Core Prerequisites
# ---------------------------------------------------------------------------

_check_core_prerequisites() {
  _section "Core Prerequisites"

  # git
  if command -v git > /dev/null 2>&1; then
    local git_ver
    git_ver=$(git --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+(\.[0-9]+)?' | head -1)
    _pass "git  ${_C_DIM}${git_ver}${_C_RESET}"
    _record_pass
  else
    _fail "git not found"
    _info "Fix: install git via your OS package manager (e.g. apt install git)"
    _record_fail
  fi

  # mise
  if command -v mise > /dev/null 2>&1; then
    local mise_ver
    mise_ver=$(mise --version 2>/dev/null | head -1 | grep -oE '[0-9]+\.[0-9]+(\.[0-9]+)?' | head -1)
    _pass "mise  ${_C_DIM}${mise_ver}${_C_RESET}"
    _record_pass
  else
    _fail "mise not found"
    _info "Fix: curl https://mise.run | sh"
    _info "     or see https://mise.jdx.dev for other install methods"
    _record_fail
    # mise is required for everything else — bail early on the mise-tool checks
    _MISE_MISSING=1
  fi
}

# ---------------------------------------------------------------------------
# Section 2: Mise Tools
# ---------------------------------------------------------------------------

# Map of mise tool name -> binary name (only entries that differ)
declare -A _MISE_BINARY_OVERRIDE=(
  ["github-cli"]="gh"
)

_check_mise_tool() {
  local tool="$1"
  local binary="${_MISE_BINARY_OVERRIDE[$tool]:-$tool}"

  local bin_path
  bin_path=$(mise which "$binary" 2>/dev/null)
  if [[ -z "$bin_path" ]]; then
    _fail "$tool not installed"
    _info "Fix: run \`mise install\` in the repo root"
    _record_fail
    return
  fi

  # Extract a clean version number from --version output.
  # Some tools (shellcheck) put the version on a "version: X.Y.Z" line.
  # Others put it inline on the first line.
  local version_output version
  version_output=$("$bin_path" --version 2>/dev/null)
  # Try "version: X.Y.Z" pattern first (shellcheck style)
  version=$(printf '%s' "$version_output" | grep -m1 -oE '^version: [0-9]+\.[0-9]+[.0-9]*' | grep -oE '[0-9]+\.[0-9]+[.0-9]*')
  if [[ -z "$version" ]]; then
    # Grab the first X.Y[.Z] token from the first line
    version=$(printf '%s' "$version_output" | head -1 | grep -oE '[0-9]+\.[0-9]+(\.[0-9]+)?' | head -1)
  fi
  if [[ -z "$version" ]]; then
    version=$(printf '%s' "$version_output" | head -1)
  fi
  _pass "$tool  ${_C_DIM}$version${_C_RESET}"
  _record_pass
}

_check_mise_tools() {
  _section "Mise Tools"

  if [[ -n "${_MISE_MISSING:-}" ]]; then
    _warn "Skipping (mise not installed)"
    _record_warn
    return
  fi

  local tools=(ruby python node uv cmake make shellcheck github-cli prek)
  for tool in "${tools[@]}"; do
    _check_mise_tool "$tool"
  done
}

# ---------------------------------------------------------------------------
# Section 3: Ruby Ecosystem
# ---------------------------------------------------------------------------

_check_ruby_ecosystem() {
  _section "Ruby Ecosystem"

  if [[ -n "${_MISE_MISSING:-}" ]]; then
    _warn "Skipping (mise not installed)"
    _record_warn
    return
  fi

  local bundle_bin
  bundle_bin=$(mise which bundle 2>/dev/null)
  if [[ -z "$bundle_bin" ]]; then
    _fail "bundle not found (is ruby installed via mise?)"
    _info "Fix: run \`mise install\`"
    _record_fail
    _GEMS_FAILED=1
    return
  fi

  if BUNDLE_GEMFILE="$ROOT/Gemfile" "$bundle_bin" check > /dev/null 2>&1; then
    _pass "Gemfile gems installed"
    _record_pass
  else
    _fail "Gemfile gems not installed"
    _info "Fix: run \`bundle install\` in the repo root"
    _record_fail
    _GEMS_FAILED=1
  fi
}

# ---------------------------------------------------------------------------
# Section 4: Node.js Ecosystem
# ---------------------------------------------------------------------------

_check_node_ecosystem() {
  _section "Node.js Ecosystem"

  if [[ -d "$ROOT/node_modules" ]]; then
    _pass "node_modules present"
    _record_pass
  else
    _fail "node_modules not found"
    _info "Fix: run \`npm ci\` in the repo root"
    _record_fail
  fi
}

# ---------------------------------------------------------------------------
# Section 5: Developer Setup
# ---------------------------------------------------------------------------

_check_developer_setup() {
  _section "Developer Setup"

  # Pre-commit hook (skip in CI)
  if [[ -v GITHUB_ACTIONS ]]; then
    _info "Pre-commit hook check skipped (CI environment)"
  else
    local git_hooks_dir
    git_hooks_dir=$(git -C "$ROOT" rev-parse --path-format=absolute --git-common-dir 2>/dev/null | tr -d '\n')
    if [[ -f "${git_hooks_dir}/hooks/pre-commit" ]]; then
      _pass "Pre-commit hook installed"
      _record_pass
    else
      _warn "Pre-commit hook not installed"
      _info "Fix: run \`bin/install_hooks\` in the repo root"
      _record_warn
    fi

    if [[ -f "${git_hooks_dir}/hooks/post-merge" ]]; then
      _pass "Post-merge hook installed"
      _record_pass
    else
      _warn "Post-merge hook not installed"
      _info "Fix: run \`bin/install_hooks\` in the repo root"
      _record_warn
    fi

    if [[ -f "${git_hooks_dir}/hooks/post-checkout" ]]; then
      _pass "Post-checkout hook installed"
      _record_pass
    else
      _warn "Post-checkout hook not installed"
      _info "Fix: run \`bin/install_hooks\` in the repo root"
      _record_warn
    fi
  fi

  # Native dependencies (z3, espresso, eqntott, must) — downloaded by bin/setup via extconf.rb
  if [[ -n "${_GEMS_FAILED:-}" ]]; then
    _warn "Native deps check skipped (Ruby gems not installed)"
    _record_warn
    return
  fi

  if [[ -n "${_MISE_MISSING:-}" ]]; then
    _warn "Native deps check skipped (mise not installed)"
    _record_warn
    return
  fi

  local ruby_bin
  ruby_bin=$(mise which ruby 2>/dev/null)
  if [[ -z "$ruby_bin" ]]; then
    _warn "Native deps check skipped (ruby not installed via mise)"
    _record_warn
    return
  fi

  local cpu
  case "$(uname -m)" in
    x86_64|x64) cpu="x64" ;;
    arm64|aarch64) cpu="arm64" ;;
    *) cpu="$(uname -m)" ;;
  esac

  local xdg_cache="${XDG_CACHE_HOME:-$HOME/.cache}"

  local espresso_version
  espresso_version=$(tr -d '[:space:]' < "$ROOT/tools/ruby-gems/udb/lib/udb/ESPRESSO_VERSION")
  _check_native_binary "espresso" "$xdg_cache/udb/espresso/$espresso_version/$cpu/espresso"

  local eqntott_version
  eqntott_version=$(tr -d '[:space:]' < "$ROOT/tools/ruby-gems/udb/lib/udb/EQNTOTT_VERSION")
  _check_native_binary "eqntott" "$xdg_cache/udb/eqntott/$eqntott_version/$cpu/eqntott"

  local must_version
  must_version=$(tr -d '[:space:]' < "$ROOT/tools/ruby-gems/udb/lib/udb/MUST_VERSION")
  _check_native_binary "must" "$xdg_cache/udb/must/$must_version/$cpu/must"

  local z3_version
  z3_version=$(tr -d '[:space:]' < "$ROOT/tools/ruby-gems/udb/lib/udb/Z3_VERSION")
  local z3_dir="$xdg_cache/udb/z3/$z3_version/$cpu"

  local z3_lib
  case "$(uname -s)" in
    Darwin) z3_lib="$z3_dir/libz3.dylib" ;;
    *)      z3_lib="$z3_dir/libz3.so" ;;
  esac

  if [[ ! -f "$z3_lib" ]]; then
    _fail "Z3 library not downloaded"
    _info "Expected: $z3_lib"
    _info "Fix: run \`bin/setup\` to download native dependencies"
    _record_fail
  else
    local z3_output z3_exit
    z3_output=$(
      BUNDLE_GEMFILE="$ROOT/Gemfile" \
        "$ruby_bin" -r udb -e "Udb::Z3Loader.ensure_z3_loaded" 2>&1
    )
    z3_exit=$?

    if [[ $z3_exit -eq 0 ]]; then
      _pass "Z3 library available"
      _record_pass
    else
      _warn "Z3 library present but failed to load"
      _info "Output: $z3_output"
      _info "Fix: run \`bin/setup\` to re-download native dependencies"
      _record_warn
    fi
  fi
}

# ---------------------------------------------------------------------------
# Section 6: C++ Toolchain
# ---------------------------------------------------------------------------

_check_cxx_toolchain() {
  _section "C++ Toolchain" "(only needed for C++ backend work)"

  # Strip bin/ from PATH to avoid wrapper recursion
  local native_path="${PATH//"${ROOT}/bin:"/}"

  # Show where the toolchain selection comes from
  if [[ -f "${ROOT}/.toolchain-local" ]]; then
    _info "Toolchain selection: .toolchain-local"
  elif [[ -n "${UDB_TOOLCHAIN_CONTAINER+x}" ]]; then
    _info "Toolchain selection: environment variable"
  else
    _info "Toolchain selection: default (native)"
  fi

  if [[ "${UDB_TOOLCHAIN_CONTAINER:-0}" = "1" ]]; then
    # --- Container mode ---
    # Source .toolchain.sh to get TOOLCHAIN_IMAGE and _get_toolchain_runtime
    # shellcheck source=.toolchain.sh
    source "${ROOT}/bin/.toolchain.sh"

    local runtime
    runtime=$(_get_toolchain_runtime)
    if [[ -z "$runtime" ]]; then
      _fail "No container runtime found (docker or podman required)"
      _info "Fix: install docker or podman"
      _record_fail
    else
      _pass "Container runtime: $runtime"
      _record_pass

      if $runtime images --format "{{.Repository}}:{{.Tag}}" 2>/dev/null | grep -qF "${TOOLCHAIN_IMAGE}"; then
        _pass "Toolchain image present (${TOOLCHAIN_IMAGE})"
        _record_pass
      else
        _fail "Toolchain image not found locally (${TOOLCHAIN_IMAGE})"
        _info "Fix: run \`bin/chore container pull -t toolchain\`"
        _info "     or:  \`bin/chore container build -t toolchain\`"
        _record_fail
      fi
    fi

    _info "To switch to native: echo 'UDB_TOOLCHAIN_CONTAINER=0' > .toolchain-local"

  else
    # --- Native mode ---
    local gpp_path
    gpp_path=$(PATH="$native_path" command -v g++ 2>/dev/null)

    if [[ -z "$gpp_path" ]]; then
      _fail "Native g++ not found"
      _info "Fix option 1: install a C++ toolchain (e.g. \`apt install build-essential\`)"
      _info "Fix option 2: echo 'UDB_TOOLCHAIN_CONTAINER=1' > .toolchain-local"
      _record_fail
    else
      local gpp_ver_line gpp_ver
      gpp_ver_line=$(PATH="$native_path" g++ --version 2>/dev/null | head -1)
      gpp_ver=$(printf '%s' "$gpp_ver_line" | grep -oE '[0-9]+\.[0-9]+(\.[0-9]+)?$')
      [[ -z "$gpp_ver" ]] && gpp_ver="$gpp_ver_line"
      _pass "Native g++  ${_C_DIM}$gpp_ver${_C_RESET}"
      _record_pass

      # Run the cmake C++23 concepts check in a subshell so exit 1 doesn't kill us
      local check_dir
      check_dir=$(mktemp -d "${TMPDIR:-/tmp}/udb-doctor-cxx-XXXXXX")
      cat > "${check_dir}/CMakeLists.txt" <<EOF
cmake_minimum_required(VERSION 3.12)
project(cxx_check CXX)
include("${ROOT}/.toolchain/check_cxx.cmake")
EOF

      local cmake_bin
      cmake_bin=$(mise which cmake 2>/dev/null)
      cmake_bin="${cmake_bin:-cmake}"

      local cmake_exit=0
      PATH="$native_path" "$cmake_bin" -S "${check_dir}" -B "${check_dir}/build" \
        --log-level=ERROR -Wno-dev > /dev/null 2>&1 || cmake_exit=$?
      rm -rf "${check_dir}"

      if [[ $cmake_exit -eq 0 ]]; then
        _pass "C++ requirements met (C++23, concepts, constexpr from_chars)"
        _record_pass
      else
        _fail "Native g++ does not meet C++ requirements (C++23 + constexpr from_chars)"
        _info "Fix option 1: install a newer compiler (GCC 14+ or Clang 17+)"
        _info "Fix option 2: echo 'UDB_TOOLCHAIN_CONTAINER=1' > .toolchain-local"
        _record_fail
      fi
    fi

    _info "To switch to container: echo 'UDB_TOOLCHAIN_CONTAINER=1' > .toolchain-local"
  fi
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

printf "${_C_BOLD}=== UDB Environment Doctor ===${_C_RESET}\n"

_check_core_prerequisites
_check_mise_tools
_check_ruby_ecosystem
_check_node_ecosystem
_check_developer_setup
_check_cxx_toolchain

# Summary
printf "\n"
if [[ $_FAIL_COUNT -eq 0 && $_WARN_COUNT -eq 0 ]]; then
  printf "${_C_BOLD}${_C_GREEN}=== Summary: $_PASS_COUNT passed, $_FAIL_COUNT failed, $_WARN_COUNT warnings ===${_C_RESET}\n"
elif [[ $_FAIL_COUNT -eq 0 ]]; then
  printf "${_C_BOLD}${_C_YELLOW}=== Summary: $_PASS_COUNT passed, $_FAIL_COUNT failed, $_WARN_COUNT warnings ===${_C_RESET}\n"
else
  printf "${_C_BOLD}${_C_RED}=== Summary: $_PASS_COUNT passed, $_FAIL_COUNT failed, $_WARN_COUNT warnings ===${_C_RESET}\n"
fi

[[ $_FAIL_COUNT -eq 0 ]]
