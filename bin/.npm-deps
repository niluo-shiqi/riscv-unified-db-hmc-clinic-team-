#!/usr/bin/env bash
# bin/.npm-deps — install/sync npm packages to a shared, hash-keyed location.
#
# Installs once per unique package-lock.json and symlinks node_modules back
# into the worktree.  Multiple worktrees with the same lockfile share a single
# installation; worktrees at different lockfile versions get independent
# directories and never clobber each other.
#
# Called by bin/setup and by git hooks (post-merge, post-checkout).

ROOT=$(dirname "$(dirname "$(realpath "${BASH_SOURCE[0]}")")")

_NPM_LOCK_HASH=$(sha256sum "$ROOT/package-lock.json" | cut -c1-16)
_NPM_SHARED="${XDG_DATA_HOME:-$HOME/.local/share}/udb/npm-$_NPM_LOCK_HASH"

_NPM_MARKER="$_NPM_SHARED/.npm-install-complete"

if [[ ! -f "$_NPM_MARKER" ]]; then
  echo "npm: installing packages (npm-$_NPM_LOCK_HASH)..."
  # Run npm ci from the repo root so it sees package.json, package-lock.json,
  # and workspaces correctly, then relocate the result to the shared path.
  rm -rf "$ROOT/node_modules" "$_NPM_SHARED"
  WD=$(pwd)
  cd "$ROOT" || exit 1
  if ! "$ROOT/bin/npm" ci; then
    echo "ERROR: npm ci failed." >&2
    exit 1
  fi
  mkdir -p "$_NPM_SHARED"
  mv "$ROOT/node_modules" "$_NPM_SHARED/node_modules"
  touch "$_NPM_MARKER"
  cd "$WD" || exit 1
  echo "npm: packages installed"
else
  echo "npm: packages up to date (npm-$_NPM_LOCK_HASH)"
fi

# Point this worktree's node_modules at the shared installation.
_NPM_LINK_TARGET="$_NPM_SHARED/node_modules"
_NPM_LINK="$ROOT/node_modules"
if [[ "$(readlink "$_NPM_LINK" 2>/dev/null)" != "$_NPM_LINK_TARGET" ]]; then
  rm -rf "$_NPM_LINK"
  ln -s "$_NPM_LINK_TARGET" "$_NPM_LINK"
fi
