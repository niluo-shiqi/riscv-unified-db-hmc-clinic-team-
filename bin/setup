#!/bin/bash
# shellcheck disable=SC2059
# bin/setup — one-command developer setup for UnifiedDB.
#
# Run this once after cloning the repository. Safe to re-run at any time;
# every step checks whether work is needed before doing it.

ROOT=$(dirname "$(dirname "$(realpath "${BASH_SOURCE[0]}")")")
cd "$ROOT" || exit 1

# ---------------------------------------------------------------------------
# Formatting helpers
# ---------------------------------------------------------------------------

if [[ -z "${NO_COLOR:-}" ]] && [[ -t 1 ]]; then
  _BOLD=$'\033[1m'
  _RESET=$'\033[0m'
  _GREEN=$'\033[32m'
  _CYAN=$'\033[36m'
  _YELLOW=$'\033[33m'
  _DIM=$'\033[2m'
else
  _BOLD='' _RESET='' _GREEN='' _CYAN='' _YELLOW='' _DIM=''
fi

_section() { printf "\n${_BOLD}${_CYAN}==> %s${_RESET}\n" "$1"; }
_ok()      { printf "    ${_GREEN}✓${_RESET}  %s\n" "$1"; }
_run()     { printf "    ${_CYAN}▶${_RESET}  %s\n" "$1"; }
_note()    { printf "    ${_YELLOW}!${_RESET}  %s\n" "$1"; }
_info()    { printf "    ${_DIM}%s${_RESET}\n" "$1"; }

printf "${_BOLD}=== UnifiedDB Setup ===${_RESET}\n"

# ---------------------------------------------------------------------------
# Install location overview
# ---------------------------------------------------------------------------

_XDG_DATA="${XDG_DATA_HOME:-$HOME/.local/share}"
_XDG_CACHE="${XDG_CACHE_HOME:-$HOME/.cache}"

_section "Install locations"
printf "    UDB follows the XDG Base Directory specification.\n"
printf "    The following directories will be used:\n\n"
printf "    %-24s  %s\n" "mise tools:"         "${MISE_DATA_DIR:-$_XDG_DATA/mise}"
printf "    %-24s  %s\n" "Ruby gems:"          "$_XDG_DATA/gem"
printf "    %-24s  %s\n" "Python packages:"    "$_XDG_DATA/udb/venv-*/"
printf "    %-24s  %s\n" "npm packages:"       "$_XDG_DATA/udb/npm-*/"
printf "    %-24s  %s\n" "Caches/native deps:" "$_XDG_CACHE/udb/"
printf "\n"

if [[ -t 0 ]] && [[ -z "${GITHUB_ACTIONS:-}" ]]; then
  printf "    Press ${_BOLD}Enter${_RESET} to continue, or type ${_BOLD}m${_RESET} to see how to change these paths: "
  read -r _SETUP_LOC_CHOICE
  if [[ "${_SETUP_LOC_CHOICE,,}" == m* ]]; then
    printf "\n"
    printf "    To change install paths, export XDG environment variables in your shell\n"
    printf "    profile (${_CYAN}~/.bashrc${_RESET}, ${_CYAN}~/.zshrc${_RESET}, etc.) before re-running setup:\n\n"
    printf "    ${_CYAN}export XDG_DATA_HOME=\"\$HOME/.local/share\"${_RESET}   # gems and npm packages\n"
    printf "    ${_CYAN}export XDG_CACHE_HOME=\"\$HOME/.cache\"${_RESET}        # caches and native deps\n\n"
    printf "    For tool-specific overrides (take precedence over XDG_DATA_HOME):\n\n"
    printf "    ${_CYAN}export MISE_DATA_DIR=\"...\"${_RESET}   # mise tools only\n"
    printf "    ${_CYAN}export BUNDLE_PATH=\"...\"${_RESET}     # Ruby gems only\n\n"
    printf "    After updating your profile, open a new shell (or source it), then re-run:\n\n"
    printf "        ${_BOLD}bin/setup${_RESET}\n\n"
    exit 0
  fi
fi

# ---------------------------------------------------------------------------
# 1. Bootstrap mise via bin/mise
# ---------------------------------------------------------------------------

_section "mise (tool version manager)"

# bin/mise is a self-bootstrapping wrapper generated by `mise generate bootstrap`.
# It downloads and caches mise on first run; subsequent runs are instant.
MISE_BIN="$ROOT/bin/mise"
_run "Bootstrapping mise..."
if ! "$MISE_BIN" --version > /dev/null 2>&1; then
  printf "\nERROR: bin/mise failed to bootstrap.\n" >&2
  exit 1
fi
_ok "mise ready ($("$MISE_BIN" --version 2>/dev/null | head -1))"

# ---------------------------------------------------------------------------
# 2. Install tool versions via mise
# ---------------------------------------------------------------------------

_section "Tool versions (Ruby, Python, Node.js, CMake, …)"

# Pre-initialize ~/.gnupg before mise install so parallel gpg invocations
# (e.g. for node, make, ruby) don't race to create the directory.
mkdir -p "${GNUPGHOME:-$HOME/.gnupg}" && chmod 700 "${GNUPGHOME:-$HOME/.gnupg}"

# mise install is idempotent and exits quickly when everything is current.
_run "Running mise install..."
if ! "$MISE_BIN" install; then
  printf "\nERROR: mise install failed.\n" >&2
  exit 1
fi
_ok "All tool versions installed"

# ---------------------------------------------------------------------------
# 3. Ruby gems
# ---------------------------------------------------------------------------

_section "Ruby gems"

if BUNDLE_GEMFILE="$ROOT/Gemfile" "$MISE_BIN" exec -- bundle check > /dev/null 2>&1; then
  _ok "Ruby gems already up to date"
else
  _run "Running bundle install..."
  if ! "$ROOT/bin/bundle" install; then
    printf "\nERROR: bundle install failed.\n" >&2
    exit 1
  fi
  _ok "Ruby gems installed"
fi

# ---------------------------------------------------------------------------
# 4. Native dependencies (z3, espresso, eqntott, must)
# ---------------------------------------------------------------------------

_section "Native dependencies (z3, espresso, eqntott, must)"

if [[ ! -f "$ROOT/ext/rbi-central/README.md" ]]; then
  _run "Initializing rbi-central submodule..."
  git submodule update --init ext/rbi-central
fi

_run "Downloading native dependencies..."
if ! (cd "${ROOT}/tools/ruby-gems/udb/ext/udb_download" && "$MISE_BIN" exec -- ruby extconf.rb); then
  printf "\nERROR: native dependency download failed.\n" >&2
  exit 1
fi
_ok "Native dependencies ready"

# ---------------------------------------------------------------------------
# 5. Python packages
# ---------------------------------------------------------------------------

_section "Python packages"

if ! "$ROOT/bin/.venv-deps"; then
  exit 1
fi

# ---------------------------------------------------------------------------
# 6. npm packages
# ---------------------------------------------------------------------------

_section "npm packages"

if ! "$ROOT/bin/.npm-deps"; then
  exit 1
fi

# ---------------------------------------------------------------------------
# 7. C++ toolchain preference
# ---------------------------------------------------------------------------

_section "C++ toolchain"

if [[ -f "$ROOT/.toolchain-local" ]]; then
  # shellcheck source=/dev/null
  source "$ROOT/.toolchain-local"
  if [[ "${UDB_TOOLCHAIN_NONE:-0}" = "1" ]]; then
    _ok "Toolchain: none/skipped (from .toolchain-local)"
  elif [[ "${UDB_TOOLCHAIN_CONTAINER:-0}" = "1" ]]; then
    _ok "Toolchain: container (from .toolchain-local)"
  else
    _ok "Toolchain: native (from .toolchain-local)"
  fi
elif [[ "${UDB_TOOLCHAIN_NONE:-0}" = "1" || "${UDB_TOOLCHAIN_CONTAINER:-0}" = "1" ]]; then
  # Non-interactive path: env vars already set (e.g. from CI).  Write .toolchain-local
  # so this choice is visible to all subsequent wrapper scripts in the same workspace.
  if [[ "${UDB_TOOLCHAIN_NONE:-0}" = "1" ]]; then
    printf "UDB_TOOLCHAIN_NONE=1\n" > "$ROOT/.toolchain-local"
    _ok "Toolchain: none/skipped (from environment)"
  else
    printf "UDB_TOOLCHAIN_CONTAINER=%s\n" "$UDB_TOOLCHAIN_CONTAINER" > "$ROOT/.toolchain-local"
    _ok "Toolchain: container (from environment)"
  fi
else
  printf "\n"
  printf "  The C++ backend requires a RISC-V toolchain. Choose how to provide it:\n\n"
  printf "  ${_BOLD}[1] Container — recommended for most users${_RESET}\n"
  printf "      Requires Docker or Podman.\n"
  printf "      A pre-built image (~500 MB) is pulled from GHCR automatically.\n"
  printf "      No compiler installation needed.\n\n"
  printf "  ${_BOLD}[2] Native${_RESET}\n"
  printf "      Requires GCC 13.3+ (or Clang 17+) with C++23 support,\n"
  printf "      plus a riscv64-unknown-elf cross-toolchain.\n"
  printf "      Faster to invoke; more setup required.\n\n"
  printf "  ${_BOLD}[3] Neither — skip for now${_RESET}\n"
  printf "      I don't plan to build the ISS.\n"
  printf "      Toolchain commands will prompt for a choice if needed later.\n\n"

  TOOLCHAIN_CHOICE=""
  while true; do
    printf "  Enter 1, 2, or 3 (default: 1): "
    read -r TOOLCHAIN_CHOICE
    TOOLCHAIN_CHOICE="${TOOLCHAIN_CHOICE:-1}"
    case "$TOOLCHAIN_CHOICE" in
      1) UDB_TOOLCHAIN_CONTAINER=1; UDB_TOOLCHAIN_NONE=0; break ;;
      2) UDB_TOOLCHAIN_CONTAINER=0; UDB_TOOLCHAIN_NONE=0; break ;;
      3) UDB_TOOLCHAIN_NONE=1; break ;;
      *) printf "  Please enter 1, 2, or 3.\n" ;;
    esac
  done

  if [[ "${UDB_TOOLCHAIN_NONE:-0}" = "1" ]]; then
    printf "UDB_TOOLCHAIN_NONE=1\n" > "$ROOT/.toolchain-local"
    _ok "Saved preference to .toolchain-local (skipping toolchain)"
  else
    printf "UDB_TOOLCHAIN_CONTAINER=%s\n" "$UDB_TOOLCHAIN_CONTAINER" > "$ROOT/.toolchain-local"
    _ok "Saved preference to .toolchain-local"
  fi
fi

# ---------------------------------------------------------------------------
# 8. Pull or build toolchain container if needed
# ---------------------------------------------------------------------------

if [[ "${UDB_TOOLCHAIN_CONTAINER:-0}" = "1" ]]; then
  _section "Toolchain container image"

  # shellcheck source=bin/.toolchain.sh
  source "${ROOT}/bin/.toolchain.sh"
  RUNTIME=$(_get_toolchain_runtime)

  if [[ -z "$RUNTIME" ]]; then
    _note "No container runtime found — skipping image pull."
    _info "Install Docker (https://docs.docker.com/engine/install) or Podman (https://podman.io/get-started)"
    _info "Then re-run bin/setup, or manually run: bin/chore container pull -t toolchain"
  elif _pull_or_build_toolchain_image; then
    _ok "Toolchain image ready"
    _info "${TOOLCHAIN_IMAGE}"
  else
    printf "\nERROR: toolchain image build failed.\n" >&2
    _info "You can retry later with: bin/chore container build -t toolchain"
  fi
fi

# ---------------------------------------------------------------------------
# 9. Git hooks
# ---------------------------------------------------------------------------

_section "Git hooks"

"$ROOT/bin/install_hooks"

# ---------------------------------------------------------------------------
# Done
# ---------------------------------------------------------------------------

printf "\n${_BOLD}${_GREEN}=== Setup complete! ===${_RESET}\n\n"

printf "${_BOLD}Next: verify your environment${_RESET}\n"
printf "  Run ${_CYAN}bin/doctor${_RESET} to confirm everything is working correctly.\n\n"

if [[ -z "${MISE_SHELL:-}" ]]; then
  printf "${_BOLD}Shell activation (recommended)${_RESET}\n"
  printf "  To use mise-managed tools (ruby, python, node, etc.) directly in your\n"
  printf "  shell without using bin/ wrappers, add the activation line to your shell\n"
  printf "  profile and open a new shell (or source the profile):\n\n"
  printf "    ${_DIM}echo 'eval \"\$(./bin/mise activate bash)\"' >> ~/.bashrc${_RESET}   # bash\n"
  printf "    ${_DIM}echo 'eval \"\$(./bin/mise activate zsh)\"'  >> ~/.zshrc${_RESET}    # zsh\n\n"
  printf "  See ${_CYAN}https://mise.jdx.dev/getting-started.html#activate-mise${_RESET} for other shells.\n\n"
fi

printf "${_BOLD}Always use the bin/ wrappers${_RESET}\n"
printf "  Prefer ${_CYAN}bin/ruby${_RESET}, ${_CYAN}bin/bundle${_RESET}, ${_CYAN}bin/python${_RESET}, ${_CYAN}bin/rake${_RESET}, etc. over invoking tools directly.\n"
printf "  The wrappers guarantee the project's pinned tool versions are used regardless\n"
printf "  of what your system shell has installed, and they transparently route C++\n"
printf "  toolchain commands through the container when UDB_TOOLCHAIN_CONTAINER=1.\n"
printf "  This keeps results consistent across machines without requiring any shell\n"
printf "  configuration beyond running this setup script.\n\n"
