#!/usr/bin/env bash
# bin/install_hooks — install git hooks for this repository.
# Safe to run multiple times; skips hooks that are already installed.
# Skipped automatically in CI (GITHUB_ACTIONS).

if [[ -v GITHUB_ACTIONS ]]; then
  exit 0
fi

ROOT=$(dirname "$(dirname "$(realpath "${BASH_SOURCE[0]}")")")
GIT_HOOKS_DIR=$(git -C "$ROOT" rev-parse --path-format=absolute --git-common-dir | tr -d '\n')/hooks
mkdir -p "$GIT_HOOKS_DIR"

# ---------------------------------------------------------------------------
# pre-commit — runs prek (pre-commit framework) on staged files
# ---------------------------------------------------------------------------
if [[ ! -f "$GIT_HOOKS_DIR/pre-commit" ]]; then
  "$ROOT/bin/prek" install
  echo "Installed pre-commit hook"
fi

# ---------------------------------------------------------------------------
# post-merge — runs install commands for any dependency files that changed
# ---------------------------------------------------------------------------
cat << 'HOOK' > "$GIT_HOOKS_DIR/post-merge"
#!/usr/bin/env bash
ROOT=$(git rev-parse --show-toplevel)
_changed=$(git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD 2>/dev/null)

if echo "$_changed" | grep -qF '.mise.toml'; then
  echo "⚙  .mise.toml changed — running mise install..."
  "${ROOT}/bin/mise" install
fi

if echo "$_changed" | grep -qF 'Gemfile.lock'; then
  echo "⚙  Gemfile.lock changed — running bundle install..."
  "$ROOT/bin/bundle" install
fi

if echo "$_changed" | grep -qF 'uv.lock'; then
  echo "⚙  uv.lock changed — syncing Python packages..."
  "$ROOT/bin/.venv-deps"
fi

if echo "$_changed" | grep -qF 'package-lock.json'; then
  echo "⚙  package-lock.json changed — syncing npm packages..."
  "$ROOT/bin/.npm-deps"
fi
HOOK
chmod +x "$GIT_HOOKS_DIR/post-merge"
echo "Installed post-merge hook"

# ---------------------------------------------------------------------------
# post-checkout — runs install commands for any dependency files that changed
# ---------------------------------------------------------------------------
cat << 'HOOK' > "$GIT_HOOKS_DIR/post-checkout"
#!/usr/bin/env bash
# $1=prev HEAD, $2=new HEAD, $3=1 if branch checkout (0 if file checkout)
# Skip file checkouts and new worktree creation (prev HEAD is null SHA)
[[ "$3" == "1" ]] || exit 0
[[ "$1" == "0000000000000000000000000000000000000000" ]] && exit 0

ROOT=$(git rev-parse --show-toplevel)
_changed=$(git diff --name-only "$1" "$2" 2>/dev/null)

if echo "$_changed" | grep -qF '.mise.toml'; then
  echo "⚙  .mise.toml changed — running mise install..."
  "${ROOT}/bin/mise" install
fi

if echo "$_changed" | grep -qF 'Gemfile.lock'; then
  echo "⚙  Gemfile.lock changed — running bundle install..."
  "$ROOT/bin/bundle" install
fi

if echo "$_changed" | grep -qF 'uv.lock'; then
  echo "⚙  uv.lock changed — syncing Python packages..."
  "$ROOT/bin/.venv-deps"
fi

if echo "$_changed" | grep -qF 'package-lock.json'; then
  echo "⚙  package-lock.json changed — syncing npm packages..."
  "$ROOT/bin/.npm-deps"
fi
HOOK
chmod +x "$GIT_HOOKS_DIR/post-checkout"
echo "Installed post-checkout hook"
