#!/bin/bash

ROOT=$(dirname "$(realpath "${BASH_SOURCE[0]}")")
[ -f "${ROOT}/../.toolchain-local" ] && source "${ROOT}/../.toolchain-local"

if [ "${UDB_TOOLCHAIN_NONE:-0}" = "1" ]; then
  # shellcheck source=.toolchain.sh
  source "${ROOT}/.toolchain.sh"
  _prompt_toolchain_selection
  source "${ROOT}/.toolchain-local"
fi

if [ "${UDB_TOOLCHAIN_CONTAINER:-0}" = "1" ]; then
  # shellcheck source=.toolchain.sh
  source "${ROOT}/.toolchain.sh"
  _setup_toolchain_run
  exec $TOOLCHAIN_RUN gdb "$@"
elif PATH="${PATH//"${ROOT}:"/}" command -v gdb > /dev/null 2>&1; then
  PATH="${PATH//"${ROOT}:"/}"
  export PATH
  exec gdb "$@"
else
  echo "ERROR: gdb not found." >&2
  echo "  Option 1: Install gdb natively (e.g., apt install gdb)" >&2
  echo "  Option 2: Set UDB_TOOLCHAIN_CONTAINER=1 to use the toolchain container" >&2
  exit 1
fi
