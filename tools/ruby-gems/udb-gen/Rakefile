# typed: true
# frozen_string_literal: true

require "pathname"
require "fileutils"

UDB_GEN_ROOT = Pathname.new Kernel.__dir__
$root ||= UDB_GEN_ROOT

file "#{UDB_GEN_ROOT}/Gemfile.lock" do
  Dir.chdir(UDB_GEN_ROOT) do
    sh "bundle install --gemfile Gemfile"
  end
end

namespace :release do
  namespace :udb_gen do
    desc "Prepare a copy of the udb-gen gem for release under gen/udb_gen_gem (or UDB_GEN_GEM_GEN_DIR)"
    task :prepare do
      udb_gen_gem_src = Pathname.new(UDB_GEN_ROOT)
      repo_root = (udb_gen_gem_src / ".." / ".." / "..").realpath
      udb_gen_gem_dst = Pathname.new(ENV.fetch("UDB_GEN_GEM_GEN_DIR", (repo_root / "gen" / "udb_gen_gem").to_s))

      puts "Preparing udb-gen gem release copy at #{udb_gen_gem_dst}"

      # Remove existing destination
      FileUtils.rm_rf(udb_gen_gem_dst)

      # Before copying, record the realpath of each top-level symlink in the source
      # so we can resolve them after the copy (the symlinks point into the monorepo
      # and would be broken at a different directory depth).
      symlink_targets = {}
      udb_gen_gem_src.children.select(&:symlink?).each do |s|
        symlink_targets[s.basename.to_s] = s.realpath
      end

      # Copy the gem source directory contents (symlinks are copied as symlinks).
      # Copy children individually so contents land directly in udb_gen_gem_dst/
      # rather than in udb_gen_gem_dst/udb-gen/ (cp_r behaviour when dst already exists).
      FileUtils.mkdir_p(udb_gen_gem_dst)
      FileUtils.cp_r(udb_gen_gem_src.children.map(&:to_s), udb_gen_gem_dst.to_s)

      # Remove Gemfile and Gemfile.lock from the copy.
      # These reference local gem paths that only exist inside the monorepo
      # and would cause `gem build` to fail elsewhere.
      FileUtils.rm_f(udb_gen_gem_dst / "Gemfile")
      FileUtils.rm_f(udb_gen_gem_dst / "Gemfile.lock")

      # Resolve (or remove) each top-level symlink in the copy
      symlink_targets.each do |name, target|
        dst_entry = udb_gen_gem_dst / name
        FileUtils.rm_rf(dst_entry)
        # Skip entries whose target doesn't exist
        next unless target.exist?

        if target.directory?
          FileUtils.cp_r(target, dst_entry)
        else
          FileUtils.cp(target, dst_entry)
        end
      end

      puts "udb-gen gem release copy ready at #{udb_gen_gem_dst}"
    end
  end
end

namespace :test do
  namespace :udb_gen do
    task :sorbet do
      Bundler.with_unbundled_env do
        Dir.chdir(UDB_GEN_ROOT) do
          Udb.logger.info "Type checking udb-gen gem"
          sh "BUNDLE_GEMFILE=#{UDB_GEN_ROOT}/Gemfile BUNDLE_FROZEN=1 bundle exec srb tc"
        end
      end
    end
  end
end
