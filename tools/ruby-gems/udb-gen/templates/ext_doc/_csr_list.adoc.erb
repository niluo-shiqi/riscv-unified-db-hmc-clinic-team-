<%#
  Copyright (c) Qualcomm Technologies, Inc. and/or its subsidiaries.
  SPDX-License-Identifier: BSD-3-Clause-Clear
  Partial: CSR summary and detail sections.
  Inputs: ext_reqs, cfg_arch, params, all_documented_csrs
-%>
[.portrait]
<<<
== CSR summary

<%- ext_reqs.each do |ext_req| -%>
<%-   csr_list = all_documented_csrs.select { |csr| ext_req.satisfying_versions.any? { |v| (-csr.defined_by_condition & v.to_condition).unsatisfiable_by_arch?(cfg_arch) } } -%>
<%-   unless csr_list.empty? -%>
<%-     unless ext_reqs.size == 1 -%>
=== <%= ext_req.name %>
<%-     end -%>

<%- Udb.logger.info "Creating CSR summary for #{ext_req}" -%>

The following <%= csr_list.size %> CSRs are affected by this extension.

[%autowidth]
|===
| RV32 | RV64 | CSR | Name <%- if ext_req.satisfying_versions.size > 1 -%>| <%= ext_req.satisfying_versions.map { |v| "v#{v.version_str}" }.join(" | ") %><%- end -%>

<%-     csr_list.each do |csr| -%>
| <%= csr.defined_in_base32? ? "&#x2713;" : "" %>
| <%= csr.defined_in_base64? ? "&#x2713;" : "" %>
| <%= link_to(csr) %>
| <%= csr.long_name %>
<%-       if ext_req.satisfying_versions.size > 1 -%>
| <%= ext_req.satisfying_versions.map { |v| (-csr.defined_by_condition & v.to_condition).unsatisfiable_by_arch?(cfg_arch) ? "&#x2713;" : "" }.join(" | ") %>
<%-       end -%>
<%-     end -%>

|===
<%-   end -%>
<%- end -%>

<<<
[#csrs,reftext="CSRs (in alphabetical order)"]
== Csrs (in alphabetical order)

<%- all_documented_csrs.each do |csr| -%>
<<<
:leveloffset: +2
<%= partial "common/csr.adoc.erb", { csr:, cfg_arch:, params: } %>
:leveloffset: -2
<%- end -%>
