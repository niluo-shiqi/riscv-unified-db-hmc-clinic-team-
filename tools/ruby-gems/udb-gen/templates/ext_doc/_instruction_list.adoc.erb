<%#
  Copyright (c) Qualcomm Technologies, Inc. and/or its subsidiaries.
  SPDX-License-Identifier: BSD-3-Clause-Clear
  Partial: instruction list section.
  Inputs: ext_reqs, cfg_arch, params, all_documented_instructions
-%>
<<<
== Instruction list

<%- ext_reqs.each do |ext_req| -%>
<%-   Udb.logger.info "Creating instruction summary for #{ext_req}" -%>
<%-   unless ext_reqs.size == 1 -%>
=== <%= ext_req.name %>
<%-   end -%>

<%-   versions = ext_req.satisfying_versions -%>
<%-   insts = all_documented_instructions.select { |i| versions.any? { |v| (i.defined_by_condition & -v.to_condition).unsatisfiable_by_arch?(cfg_arch) } } -%>

<%-   unless insts.empty? -%>
The following <%= insts.size %> instructions must be implemented when <%= ext_req.name %> is implemented:

.Instructions defined by <%= ext_req.to_s_pretty %>
[cols="1,1,5,5"]
|===
| RV32 | RV64 | Mnemonic | Instruction <%- if versions.size > 1 -%> | <%= versions.map { |v| "v#{v.version_str}" }.join(" | ") %><%- end -%>

<%-     insts.each do |i| -%>
| <%= i.rv32? ? "&#x2713;" : "" %>
| <%= i.rv64? ? "&#x2713;" : "" %>
| `<%= [i.name, i.assembly.gsub("x", "r").strip].join(" ").strip %>`
| <%= link_to(i, i.long_name) %>
<%-       if versions.size > 1 -%>
| <%= versions.map { |v| (-i.defined_by_condition & v.to_condition_exclusive).unsatisfiable_by_arch?(cfg_arch) ? "&#x2713;" : "" }.join(" | ") %>
<%-       end -%>
<%-     end -%>
|===
<%-   end -%>


<%-   if params[:include_implies] -%>
<%-     implied_insts = all_documented_instructions.select { |i| versions.any? { |v| (-i.defined_by_condition & v.requirements_condition).unsatisfiable_by_arch?(cfg_arch) } } -%>
<%-     Udb.logger.info "Found #{implied_insts.size} implied instructions for #{ext_req.name}." unless implied_insts.empty? -%>
<%-     unless implied_insts.empty? -%>
<%= insts.empty? ? "The" : "Additionally, the" %> following <%= implied_insts.size %> instructions are implied by the requirements
of this extension.

.<%= ext_req %> requirements
--
<%= ext_req.satisfying_versions.size == 1 ? ext_req.satisfying_versions.fetch(0).requirements_condition.to_asciidoc : ext_req.requirements_condition.to_asciidoc %>
--

.Instructions implied by <%= ext_req.to_s_pretty %>
[cols="4,4,1",separator="^"]
|===
^ Mnemonic ^ Instruction ^ Defined by

<%-       implied_insts.sort.each do |i| -%>
^ `<%= [i.name, i.assembly.gsub("x", "r").strip].join(" ").strip %>`
^ <%= link_to(i, i.long_name) %>
a^ <%= i.defined_by_condition.to_asciidoc %>
<%-       end -%>
|===

<%-     end -%>
<%-   end -%>

<%- end -%>

<%- if ext_reqs.size > 1 -%>
[.landscape]
<<<
== Instruction Summary
<%- Udb.logger.info "Creating instruction summary" -%>

[%autowidth]
|===
| Mnemonic | <%= ext_reqs.map { |e| "`#{e.name}`" }.join(" | ") %>

<%-   all_documented_instructions.each do |i| -%>
| `<%= i.name %>`
| <%= ext_reqs.map { |e| (-i.defined_by_condition & e.to_condition).unsatisfiable_by_arch?(cfg_arch) ? "&#x2713;" : "" }.join(" | ") %>
<%-   end -%>
|===

<%- end -%>
