<%- max_version = ext_reqs[0].satisfying_versions.max -%>
<%= partial "ext_doc/_header.adoc.erb", {
  long_name:      primary_ext.long_name,
  ext_name:       ext_reqs[0].name,
  revdate:        revdate(max_version),
  version_spec:   max_version.version_spec,
  revmark:        state_revmark(max_version),
  company:        company_name(primary_ext),
  is_riscv:       riscv_branded?(primary_ext),
  is_development: max_version.state == "development"
} %>
= <%= primary_ext.long_name %>

<%= partial "ext_doc/_preamble.adoc.erb", {
  state_preamble: state_preamble_adoc(max_version),
  license_url:    doc_license_url(primary_ext),
  license_name:   doc_license_name(primary_ext),
  company:        company_name(primary_ext),
  copyright_year: copyright_year(max_version),
  git_commit:     `git rev-parse HEAD`,
  ext_reqs:,
  cfg_arch:
} %>

<<<
== Conventions

Version requirements are specified as conditions using the following operators:

[cols="1,2"]
|===
| Operator | Meaning

| `~> VERSION` | Accepts any version that is _compatible_ with `VERSION`. By default, a version A is compatible with a version B if A's version number is greater than or equal to version B. If that default assumption is ever broken, it will be noted in the list of extension versions.
| `= VERSION` | Accepts only version `VERSION`.
| `>= VERSION` | Accepts any version greater than or equal to `VERSION`.
| `\<= VERSION` | Accepts any version less than or equal to `VERSION`.
| `> VERSION` | Accepts any version greater than `VERSION`.
| `< VERSION` | Accepts any version less than `VERSION`.
|===

<<<
== Extension description

<%- ext_reqs.each do |ext_req| -%>

:leveloffset: +2
<%= ext_req.extension.description %>
:leveloffset: -2

<%-   has_requirements = ext_req.satisfying_versions.any? { |v| !v.defining_extension_requirements.empty? } -%>
<%-   if has_requirements -%>
=== Requirements
<%-     ext_req.satisfying_versions.each do |version| -%>
<%-       unless version.defining_extension_requirements.empty? -%>

<%= version.name %> has the following requirements:

|===
| Extension | Version | When

<%-         version.defining_extension_requirements.sort { |a, b| a.ext_req <=> b.ext_req }.each do |cond_ext_req| -%>
| <%= cond_ext_req.ext_req.name %>
| <%= cond_ext_req.ext_req.requirement_specs_to_s_pretty %>
| <%= cond_ext_req.cond.empty? ? "always" : cond_ext_req.cond.to_asciidoc %>
<%-         end -%>

|===
<%-       end -%>
<%-     end -%>
<%-   end -%>
<%- end -%>

<%- Udb::LogicNode.reset_stats -%>

<%- any_ext = Udb::Condition.disjunction(ext_reqs.map { |e| e.extension.to_condition }, cfg_arch) -%>
<%- all_exts = Udb::Condition.disjunction(ext_reqs.map { |e| e.to_condition }, cfg_arch) -%>

<%# all_documented_instructions are all of the instructions that must be implemented when the target extension requirements are met.
    It may be more than what we actually want to document because transitive requirements are going to be included.
%>
<%- pb = Udb.create_progressbar("Discovering which instructions need to be documented [:bar] :current/:total", total: cfg_arch.instructions.size, clear: true) -%>
<%- all_documented_instructions = cfg_arch.instructions.select { |inst| pb.advance; (-any_ext & inst.defined_by_condition).unsatisfiable_by_arch?(cfg_arch) } -%>

<%# now reject any instructions that are only defined in an extension version that isn't met by our requirements -%>
<%- all_documented_instructions.select! { |inst| (all_exts & inst.defined_by_condition).satisfiable_by_arch?(cfg_arch) } -%>

<%- Udb.logger.info "Found #{all_documented_instructions.size} instructions to include in documentation" -%>
<%- Udb.logger.info "#{all_documented_instructions.map(&:name)}" -%>

<%- unless all_documented_instructions.empty? -%>
<%= partial "ext_doc/_instruction_list.adoc.erb", { ext_reqs:, cfg_arch:, params:, all_documented_instructions: } %>
<%- end -%>

<%- Udb.logger.info "Determining relevant CSRs" -%>

<%- pb = Udb.create_progressbar("Discovering which csrs need to be documented [:bar] :current/:total", total: cfg_arch.csrs.size, clear: true) -%>
<%- all_documented_csrs = cfg_arch.csrs.select { |csr| pb.advance; (-any_ext & csr.defined_by_condition).unsatisfiable_by_arch?(cfg_arch) } -%>
<%# now reject any csrs that are only defined in an extension version that isn't met by our requirements -%>
<%- all_documented_csrs.select! { |csr| (all_exts & csr.defined_by_condition).satisfiable_by_arch?(cfg_arch) } -%>

<%- Udb.logger.info "Found #{all_documented_csrs.size} relevant CSRs" -%>
<%- unless all_documented_csrs.empty? -%>
<%= partial "ext_doc/_csr_list.adoc.erb", { ext_reqs:, cfg_arch:, params:, all_documented_csrs: } %>
<%- end -%>

<%- unless all_documented_instructions.empty? -%>
[.portrait]
<<<
[#insns,reftext="Instructions (in alphabetical order)"]
== Instructions (in alphabetical order)

<%- bar = Udb.create_progressbar("Creating instruction definitions [:bar] :current/:total", total: all_documented_instructions.size) -%>
<%-   all_documented_instructions.sort.each do |i| -%>
:leveloffset: +2
<%- bar.advance -%>
<%= partial "common/inst.adoc.erb", { inst: i, cfg_arch:, ext_reqs: } %>
:leveloffset: -2

<<<
<%-   end -%>
<%- end -%>

<%-
  cache = T.let({ 32 => {}, 64 => {}, nil => {} }, T::Hash[Integer, Idl::AstNode::ReachableFunctionCacheType])
  reachable_functions = all_documented_instructions.map do |i|
   f = []
   f += i.reachable_functions(32, cache.fetch(32)) if cfg_arch.possible_xlen?(32) && i.defined_in_base?(32)
   f += i.reachable_functions(64, cache.fetch(64)) if cfg_arch.possible_xlen?(64) && i.defined_in_base?(64)
   f
  end
  reachable_functions += all_documented_csrs.map do |csr|
    f = []
    f += csr.reachable_functions(32, cache) if cfg_arch.possible_xlen?(32) && csr.defined_in_base?(32)
    f += csr.reachable_functions(64, cache) if cfg_arch.possible_xlen?(64) && csr.defined_in_base?(64)
    f
  end
  reachable_functions = reachable_functions.flatten.uniq
-%>
<%= partial "ext_doc/_idl_functions.adoc.erb", { reachable_functions:, cfg_arch: } %>
