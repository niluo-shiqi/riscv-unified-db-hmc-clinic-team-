<%#
  Copyright (c) Qualcomm Technologies, Inc. and/or its subsidiaries.
  SPDX-License-Identifier: BSD-3-Clause-Clear
  Partial: AsciiDoc header attributes for an extension PDF document.
  Inputs: long_name, ext_name, revdate, version_spec, revmark, company, is_riscv, is_development
-%>
[[header]]
:description: <%= long_name %> (<%= ext_name %>)
:revdate: <%= revdate %>
:revnumber: <%= version_spec %>
:revmark: <%= revmark %>
:company: <%= company %>
:url-riscv: https://riscv.org
:doctype: book
:preface-title: Licensing and Acknowledgements
:colophon:
:appendix-caption: Appendix
<%- if is_riscv -%>
:title-logo-image: image:risc-v_logo.png["RISC-V International Logo",pdfwidth=3.25in,align=center]
:back-cover-image: image:riscv-horizontal-color.svg[opacity=25%]
<%- end -%>
<%- if is_development -%>
:page-background-image: image:draft.png[opacity=20%]
<%- end -%>
// Settings
:experimental:
:reproducible:
// needs to be changed
:imagesoutdir: images
:icons: font
:lang: en
:example-caption: Example
:listing-caption: Listing
:table-caption: Table
:figure-caption: Figure
:xrefstyle: short
:chapter-refsig: Chapter
:section-refsig: Section
:appendix-refsig: Appendix
:sectnums:
:toc: left
:toclevels: 2
:source-highlighter: pygments
ifdef::backend-pdf[]
:source-highlighter: rouge
endif::[]
:data-uri:
:hide-uri-scheme:
:stem:
:footnote:
:stem: latexmath
:footnote:
:le: &#8804;
:ge: &#8805;
:ne: &#8800;
:approx: &#8776;
:inf: &#8734;
