# typed: true
# frozen_string_literal: true

require "pathname"
require "fileutils"

UDB_HELPERS_ROOT = Kernel.__dir__

namespace :release do
  namespace :udb_helpers do
    desc "Prepare a copy of the udb_helpers gem for release under gen/udb_helpers_gem (or UDB_HELPERS_GEM_GEN_DIR)"
    task :prepare do
      udb_helpers_gem_src = Pathname.new(UDB_HELPERS_ROOT)
      repo_root = (udb_helpers_gem_src / ".." / ".." / "..").realpath
      udb_helpers_gem_dst = Pathname.new(ENV.fetch("UDB_HELPERS_GEM_GEN_DIR", (repo_root / "gen" / "udb_helpers_gem").to_s))

      puts "Preparing udb_helpers gem release copy at #{udb_helpers_gem_dst}"

      # Remove existing destination
      FileUtils.rm_rf(udb_helpers_gem_dst)

      # Before copying, record the realpath of each top-level symlink in the source
      # so we can resolve them after the copy (the symlinks point into the monorepo
      # and would be broken at a different directory depth).
      symlink_targets = {}
      udb_helpers_gem_src.children.select(&:symlink?).each do |s|
        symlink_targets[s.basename.to_s] = s.realpath
      end

      # Copy the gem source directory contents (symlinks are copied as symlinks).
      # Copy children individually so contents land directly in udb_helpers_gem_dst/
      # rather than in udb_helpers_gem_dst/udb_helpers/ (cp_r behaviour when dst already exists).
      FileUtils.mkdir_p(udb_helpers_gem_dst)
      FileUtils.cp_r(udb_helpers_gem_src.children.map(&:to_s), udb_helpers_gem_dst.to_s)

      # Remove Gemfile and Gemfile.lock from the copy.
      # These reference local gem paths that only exist inside the monorepo
      # and would cause `gem build` to fail elsewhere.
      FileUtils.rm_f(udb_helpers_gem_dst / "Gemfile")
      FileUtils.rm_f(udb_helpers_gem_dst / "Gemfile.lock")

      # Resolve (or remove) each top-level symlink in the copy
      symlink_targets.each do |name, target|
        dst_entry = udb_helpers_gem_dst / name
        FileUtils.rm_rf(dst_entry)
        # Skip entries whose target doesn't exist
        next unless target.exist?

        if target.directory?
          FileUtils.cp_r(target, dst_entry)
        else
          FileUtils.cp(target, dst_entry)
        end
      end

      puts "udb_helpers gem release copy ready at #{udb_helpers_gem_dst}"
    end
  end
end

namespace :test do
  namespace :udb_helpers do
    desc "Run unit tests for the udb_helpers gem"
    task :unit do
      Dir.chdir(UDB_HELPERS_ROOT) do
        sh "ruby -Ilib:test test/run.rb"
      end
    end
  end
end
