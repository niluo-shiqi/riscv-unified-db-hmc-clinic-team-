# typed: true
# frozen_string_literal: true

require "pathname"
require "fileutils"

RUBY_UDB_ROOT = Kernel.__dir__

namespace :release do
  namespace :udb do
    desc "Prepare a copy of the udb gem for release under gen/udb_gem (or UDB_GEM_GEN_DIR)"
    task :prepare do
      udb_gem_src = Pathname.new(RUBY_UDB_ROOT)
      repo_root = (udb_gem_src / ".." / ".." / "..").realpath
      udb_gem_dst = Pathname.new(ENV.fetch("UDB_GEM_GEN_DIR", (repo_root / "gen" / "udb_gem").to_s))

      puts "Preparing udb gem release copy at #{udb_gem_dst}"

      # Remove existing destination
      FileUtils.rm_rf(udb_gem_dst)

      # Before copying, record the realpath of each top-level symlink in the source
      # so we can resolve them after the copy (the symlinks point into the monorepo
      # and would be broken at a different directory depth).
      symlink_targets = {}
      udb_gem_src.children.select(&:symlink?).each do |s|
        symlink_targets[s.basename.to_s] = s.realpath
      end

      # Copy the gem source directory contents (symlinks are copied as symlinks).
      # Copy children individually so contents land directly in udb_gem_dst/
      # rather than in udb_gem_dst/udb/ (cp_r behaviour when dst already exists).
      FileUtils.mkdir_p(udb_gem_dst)
      FileUtils.cp_r(udb_gem_src.children.map(&:to_s), udb_gem_dst.to_s)

      # Remove Gemfile and Gemfile.lock from the copy.
      # These reference local gem paths (../idlc, ../udb_helpers) that only
      # exist inside the monorepo and would cause `gem build` to fail elsewhere.
      FileUtils.rm_f(udb_gem_dst / "Gemfile")
      FileUtils.rm_f(udb_gem_dst / "Gemfile.lock")

      # Resolve (or remove) each top-level symlink in the copy
      symlink_targets.each do |name, target|
        dst_entry = udb_gem_dst / name
        FileUtils.rm_rf(dst_entry)
        # Skip entries whose target doesn't exist (e.g. ext/rbi-central when
        # the submodule isn't checked out) and the schemas symlink (not needed
        # in the gem; data is under .data/ instead)
        next unless target.exist?
        next if name == "schemas"  # symlink to spec/schemas; not needed in gem copy

        if target.directory?
          FileUtils.cp_r(target, dst_entry)
        else
          FileUtils.cp(target, dst_entry)
        end
      end

      # Populate .data/ with the required data files from the monorepo
      data_dir = udb_gem_dst / ".data"
      {
        (repo_root / "spec" / "std" / "isa")    => (data_dir / "spec" / "std" / "isa"),
        (repo_root / "spec" / "custom" / "isa") => (data_dir / "spec" / "custom" / "isa"),
        (repo_root / "spec" / "schemas")        => (data_dir / "spec" / "schemas"),
        (repo_root / "cfgs")                    => (data_dir / "cfgs")
      }.each do |src, dst|
        FileUtils.mkdir_p(dst.dirname)
        FileUtils.cp_r(src, dst)
      end

      puts "udb gem release copy ready at #{udb_gem_dst}"
    end
  end
end

namespace :gen do
  namespace :udb do
    desc "Generate the UDB Ruby API documentation"
    task "ruby-doc" do
      sh "yard doc"
    end
  end
end

# initialize sorbet
file "#{RUBY_UDB_ROOT}/Gemfile.lock" do
  Dir.chdir(RUBY_UDB_ROOT) do
    sh "bundle install --gemfile Gemfile"
  end
end

# initialize sorbet
namespace :chore do
  namespace :udb do

    task :lsp do
      Bundler.with_unbundled_env do
        Dir.chdir(RUBY_UDB_ROOT) do
          sh "BUNDLE_GEMFILE=#{RUBY_UDB_ROOT}/Gemfile BUNDLE_FROZEN=1 bundle exec srb tc --lsp --disable-watchman"
        end
      end
    end

    task :collate_cov, [:cov_dir] do |t, args|
      require "simplecov"
      require "simplecov-cobertura"

      SimpleCov.collate Dir["#{args[:cov_dir]}/*.resultset.json"] do
        coverage_dir ("#{RUBY_UDB_ROOT}/coverage").to_s
        formatter SimpleCov::Formatter::MultiFormatter.new([
          SimpleCov::Formatter::CoberturaFormatter,
          SimpleCov::Formatter::HTMLFormatter,
        ])
      end
    end
  end
end

namespace :gen do
  namespace :udb do
    task :api_doc do
      Dir.chdir(RUBY_UDB_ROOT) do
        FileUtils.rm_rf $root / "gen" / "udb_api_doc"
        sh "bundle exec yard --plugin sorbet lib --no-save --embed-mixins --hide-void-return -o #{$root}/gen/udb_api_doc"
      end
    end
  end
end

namespace :test do
  namespace :udb do
    desc "Type check the Ruby UDB source code"
    task sorbet: "#{RUBY_UDB_ROOT}/sorbet/config" do
      Bundler.with_unbundled_env do
        Dir.chdir(RUBY_UDB_ROOT) do
          Udb.logger.info "Type checking udb gem"
          sh "BUNDLE_GEMFILE=#{RUBY_UDB_ROOT}/Gemfile BUNDLE_FROZEN=1 bundle exec srb tc"
        end
      end
    end

    desc "Run unit tests for the udb gem"
    task :unit do
      Dir.chdir(RUBY_UDB_ROOT) do
        Udb.logger.info "Type checking udb gem"
        sh "ruby -Ilib:test test/run.rb"
      end
    end
  end
end
