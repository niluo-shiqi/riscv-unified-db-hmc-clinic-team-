grammar org.xtext.example.udb.Udb with org.eclipse.xtext.common.Terminals
hidden(SL_COMMENT, WS)
generate udb "http://www.xtext.org/example/udb/Udb"

import "http://www.eclipse.org/emf/2002/Ecore" as ecore

Model 
	: CsrModel
	| InstModel
	| ExtModel
	| InterruptCodeModel
	| ExceptionCodeModel
	| InstOpcodeModel
	| InstVarTypeModel
	| RegisterModel
	| ManualModel
	| ManualVersionModel
	| ProfFamModel
;



CsrModel:
	schema = Schema // must be "csr_schema.json#"
	csrKind = CsrKind
	csrName = CsrName &
	longName = LongName &
	description = Description &
	definedBy = DefinedBy &
	address = CsrAddress &
	indirectAddress = CsrIndirectAddress? &
	indirectSlot = CsrIndirectSlot? &
	writable = CsrWritable &
	privmode = CsrPrivMode &
	virtualAddress = CsrVirtualAddress? &
	length = CsrLength &
	requires = CsrRequires? &
	csrFields = CsrFields? &
	swRead = CsrSwRead? &
	source = Source? &
	certNormativeRules = CertNormativeRules?
;

InstModel:
	schema = Schema // must be "inst_schema.json#"
	kind = InstKind
	instName = InstName &
	longName = LongName &
	description = Description &
	definedBy = DefinedBy &
	hints = InstHints? &
	access = InstAccess &
	accessDetail = InstAccessDetail? &
	operation = InstOperation? &
	operationAst = InstOperationAst? &
	certNormativeRules = CertNormativeRules? &
	assembly = InstAssembly &
	dataIndependentTiming = InstDataIndependentTiming? &
	pseudoInstructions = InstPseudoInstructions? &
	source = Source? &
	format = InstFormat? &
	encoding = InstEncoding?
;

ExtModel:
	schema = Schema // must be "ext_schema.json#"
	extKind = ExtKind
	extName = ExtName &
	longName = LongName &
	description = Description &
	rviJiraIssue = ExtRviJiraIssue? &
	company = Company? &
	docLicense = DocLicense? &
	type = ExtType &
	requirements = Requirements? &
	extVersions = ExtVersions &
	source = Source? &
	certNormativeRules = CertNormativeRules?
;

//ProfModel:
//	schema = Schema // must be "profile_schema.json#"
//	profKind = ProfKind
//	profName = ProfName &
//	longName = LongName &
//	description = Description? &
//	inherits = ProfInherits? &
//	parentOf = ProfParentOf? &
//	childOf = ProfChildOf? &
//	certNormativeRules = CertNormativeRules? &
//	requirements = Requirements? &
//	marketingName = ProfMarketingName &
//	mode = ProfMode? &
//	release = ProfRelease? &
//	introduction = ProfIntroduction? &
//	recommendations = ProfRecommendations? &
//	extraNotes = ProfExtraNotes? &
//	extensions = ProfExtensions? &
//	source = ProfSource?
//;

InterruptCodeModel:
	schema = Schema // must be "interript_code_schema.json#"
	intrptCodeKind = IntrptCodeKind
	intrptCodeName = IntrptCodeName &
	displayName = DisplayName &
	intrptNum = IntrptCodeNum &
	definedBy = DefinedBy &
	source = Source?
;

ExceptionCodeModel:
	schema = Schema // must be "exception_code_schema.json#"
	ecKind = ECKind
	ecName = ECName &
	displayName = DisplayName &
	num = Num &
	definedBy = DefinedBy &
	source = Source?
;

InstOpcodeModel:
	schema = Schema // must be "inst_opcode_schema.json#"
	instOpcodeKind = InstOpcodeKind
	instOpcodeName = InstOpcodeName? &
	instOpcodedata = InstOpcodeData
;

InstVarTypeModel:
	schema = Schema
	instVarTypeKind = InstVarTypeKind
	instVarTypeName = InstVarTypeName &
	instVarTypeType = InstVarTypeType &
	registerFile = RegisterFile? &
	access = InstVarTypeAccess?
	
;

RegisterModel:
	schema = Schema // must be "register_file_schema.json#"
	regKind = RegisterKind
	regName = RegisterName &
	longName = LongName &
	description = Description &
	definedBy = RegisterDefinedBy? &
	registerClass = RegisterClass? &
	registerLength = RegisterLength &
	registers = Registers &
	source = Source?
	
;

ManualModel:
	schema = Schema // must be "manual_schema.json#"
	manualKind = ManualKind
	manualName = ManualName &
	longName = LongName &
	marketingName = MarketingName? &
	state = SpecState? &
	url = Url? &
	license = License? &
	source = Source?
;
ManualVersionModel:
	schema = Schema // must be "manual_version_schema.json#"
	manualVersionKind = ManualVersionKind
	manualVersionName = ManualVersionName &
	longName = LongName &
	manual = ManualVersionManual &
	version = ManualVersionVersion &
	marketingVersion = MarketingVersion &
	state = ManualVersionState &
	url = Url? &
	usesIsaManual = UsesIsaManual? &
	isaManualTree = IsaManualTree? &
	volumes = ManualVersionVolumes &
	source = Source?
;

ProfFamModel:
	schema = Schema
	profFamKind = PFKind
	& processorKind = ProcessorKind? 
	& profFamName = PFName 
	& longName = LongName 
	& marketingName = PFMarketingName? 
	& introduction = Introduction? 
	& description = Description? 
	& namingScheme = PFNamingScheme? 
	& company = Company? 
	& docLicense = DocLicense? 
	& source = Source? 
;

/*
 * Common stuff
 */
Schema: "$schema" ":" schema=STRING;
LongName: 'long_name' ":" longName=STRING;
Description: 'description' ':' description=DescriptionType;
DescriptionType: (value=STRING) | MultilineString;
Requirements: "requirements" ":" 
	INDENT 
		requirements=Condition 
	DEDENT
;
DefinedBy: "definedBy" ":" 
	INDENT 
		definedBy=Condition
	DEDENT
;
DisplayName:'display_name' ':' displayName=STRING;
Source:'$source' ':' source=STRING;
Number: intVal=INT | bin=Bin | hex=Hex;
Range: upper=INT '-' lower=INT;
UdbId: 'id' ':' id=STRING;
Url: 'url' ':' url=STRING;
TextUrl: 'text_url' ':' textUrl=STRING;
Email: 'email' ':' email=STRING;
ProcessorKind: 'processor_kind' ':' 
	processorKind=('Generic_Unprivileged' | "Microcontroller" | 'Apps_Processor');
Introduction: 'introduction' ':' introduction=STRING;
Company:
	'company' ':' 
	INDENT (
		('name' ':' name=STRING) &
		 url=Url?
	) DEDENT 
;

// IDL gets passed off to ruby in the validator
Idl: '|' idl=STRING;

// see "cert_normative_rules" in schema_defs.json
// TODO: not tested
CertNormativeRules:
	'cert_normative_rules' ':'
	INDENT
		rules += CNRuleArrayElement+
	DEDENT
;
CNRuleArrayElement:
	'-' id = UdbId
	INDENT (
		('name' ':' name = STRING) &
		docLinks = DocLinks &
		description = Description
	) DEDENT
;
DocLinks:
	"doc_links" ":"
	INDENT
		links += DocLinksArrayElement+
	DEDENT
;
DocLinksArrayElement:
	'-' link = STRING
;

// see "license" in schema_defs.json
DocLicense:
	'doc_license' ':'
	INDENT (
		('name' ':' name=STRING) &
		id=UdbId? &
		url=Url? &
		textUrl=TextUrl?
	) DEDENT
;

License:
	'license' ':'
	INDENT (
		('name' ':' name=STRING) & 
		id=UdbId? &
		url=Url? &
		textUrl=TextUrl?
	) DEDENT
;



/*
 * CSR stuff (see csr_schema.json)
 */
CsrKind: 'kind' ':' kind="csr";
CsrName: 'name' ':' name=STRING;
CsrAddress: 'address' ':' address=Hex;
CsrWritable: 'writable' ':' writable=Boolean;
CsrIndirectAddress:'indirect_address' ':' indirectAddress=Hex;
CsrIndirectSlot:'indirect_slot' ':' indirectSlot=INT ;
CsrVirtualAddress:'virtual_address' ':' virtualAddress=Hex;
CsrSwRead:'sw_read()' ':' swRead=Idl;
CsrPrivMode:'priv_mode' ':' privMode=("M"|"S"|"U"|"VS"|"D");
CsrLength: 'length' ':' length=CsrLengthType;
CsrLengthType: intType = CsrIntType | parmType = CsrParmType;
CsrIntType: intVal=INT;
CsrParmType: parmName=('MXLEN'|'SXLEN'|'VSXLEN'|'XLEN');

// extension that must be implemented for this CSR to exist
CsrRequires:'requires' ':' requires=STRING;

// grammar for csr_field
CsrFields:
	{CsrFields} 'fields' ':'
	INDENT
    	fields += CsrFieldDef+
    DEDENT
;

CsrFieldDef:
	name=STRING ':'
	INDENT (
		displayName = CsrFieldDisplayName? &
		longName = LongName? &
		location = CsrFieldLocationType &
		resetValue = CsrFieldResetValueType &
		swWriteFunc = CsrFieldSWWriteFunc? &
		legalFunc = CsrFieldLegalFunc? &
		description = Description &
		type = CsrFieldTypeType &
		alias = CsrFieldAlias? &
		definedBy = DefinedBy? &
		affectedBy = CsrFieldAffectedBy? &
		certNormativeRules = CertNormativeRules?
	) DEDENT
;


CsrFieldDisplayName: 'name' ':' fieldName=STRING ;

CsrFieldLocationType: staticLoc = CsrStaticLocation | funcLoc = CsrVarLocation;
CsrStaticLocation: 'location' ':' locValue=CsrFieldLocation;
CsrVarLocation:
	locationRV32=LocationRV32 &
	locationRV64=LocationRV64
;
LocationRV32: "location_rv32" ":" locationRV32=CsrFieldLocation;
LocationRV64: "location_rv64" ":" locationRV64=CsrFieldLocation;
CsrFieldLocation: value=INT | range=Range;

CsrFieldResetValueType: value=CsrFieldResetValue | function=CsrFieldResetValueFunc;
CsrFieldResetValue: "reset_value" ":" resetValue=CsrFieldResetValueValue;
CsrFieldResetValueValue: value=INT | undefinedLegal=UndefinedLegal;
CsrFieldResetValueFunc: "reset_value()" ":" resetValueFunc=Idl;

CsrFieldSWWriteFunc: "sw_write(csr_value)" ":" swWriteFunc=Idl;
CsrFieldLegalFunc: "legal?(csr_value)" ":" legalFunc=Idl;

CsrFieldTypeType: typeVal=CsrFieldType | typeFunc=CsrFieldTypeFunc;
CsrFieldType: "type" ":" perms=("RO"|"RO-H"|"RW"|"RW-R"|"RW-H"|"RW-RH");
CsrFieldTypeFunc: "type()" ":" idl=Idl;

CsrFieldAlias: "alias" ":" (aliasName=CsrFieldAliasName | aliasArray=CsrFieldAliasArray);
CsrFieldAliasName: name=STRING;
CsrFieldAliasArray:
	"items" ":"
	INDENT
		aliases += CsrAliasArrayElement+
	DEDENT
;
CsrAliasArrayElement:
	"-" alias = CsrFieldAliasName
;


CsrFieldAffectedBy:
    "affectedBy" ":" value=CsrAffectedByValue
;

CsrAffectedByValue:
    CsrAffectedBySingle | CsrAffectedByList
;

CsrAffectedBySingle:
    ref=[ExtModel|STRING]
;

CsrAffectedByList:
    "[" refs+=[ExtModel|STRING] ("," refs+=[ExtModel|STRING])* "]"
;



/*
 * Instruction stuff (see inst_schema.json)
 */
InstKind: 'kind' ':' kind="instruction";
InstName: 'name' ':' name=STRING;
InstAccess:
	'access' ':'
	INDENT(
	('m' ':' m=InstAccessType)? &
	's' ':' s=InstAccessType &
	'u' ':' u=InstAccessType &
	'vs' ':' vs=InstAccessType &
	'vu' ':' vu=InstAccessType
	)DEDENT
;
InstAccessType:
	accessLevel=('always'|'sometimes'|'never')
;
InstAssembly: 'assembly' ':' assembly=STRING;

/* Optional fields for the INST schema */
InstOperationAst: 'operation_ast' ':' operationAst=STRING;
InstHints:
	'hints' ':'
	INDENT
		hints += InstHintElement+
	DEDENT
;
InstHintElement: '-' '{' hint = STRING '}';

InstAccessDetail: 'access_detail' ':' accessDetail=STRING;
InstOperation: 'operation()' ':' operation=Idl;
InstDataIndependentTiming: 'data_independent_timing' ':' dataIndependentTiming=Boolean;
InstPseudoInstructions: 'pseudoinstructions' ':' pseudoInstructions=Array;
InstFormat: 'format' ':'
	INDENT (
		'$inherits' ':' inherits=InstInheritType &
		'opcodes' ':' opcodes=InstOpcodeType
	)DEDENT
;
InstInheritType:
	INDENT
		('-' reference += STRING)+ 
	DEDENT
;

InstOpcodeType:
	INDENT
		opcode += InstOpcodeEntry+
	DEDENT
;
InstOpcodeEntry:
	InstOpcodeField
	| InstOpcodeInherits
;

InstOpcodeField: 
	name=STRING ':'
	INDENT
		(opcodeProperties += InstOpcodeProps)+
	DEDENT

;

InstOpcodeProps:
	'display_name' ':' displayName=STRING
	| 'value' ':' value=Number
;

InstOpcodeInherits:
	'opcode' ':' '{' '$inherits' ':' inheritsAddress=STRING '}'
;


InstEncoding:
	'encoding' ':'
	(
		InstRvPairEncoding
		| InstOldEncoding
	)
;

InstOldEncoding:
	{InstOldEncoding}
	INDENT(
	    match=InstEncodingMatch &
	    variables=InstEncodingVariables?
  	)DEDENT
;
InstEncodingMatch:
	'match' ':' pattern=STRING
;

InstEncodingVariables:
	'variables' ':'
	  INDENT
	    (vars += InstEncodingTwoKeyVar+ | vars += InstEncodingSevenKeyVar+)
	  DEDENT
;


InstEncodingSevenKeyVar:
  '-' 'name' ':' name=STRING
  INDENT
    (
      'location' ':' location=Range &
      ('$child_of' ':' childOf=STRING)? & 
      ('sign_extend' ':' signExtend=Boolean)? & 
      ('left_shift' ':' leftShift=INT)? &
      ('alias' ':' alias=STRING)? &
      ('not' ':' not=InstNotRule)?
    )
  DEDENT
;

InstNotRule:
	{NotRule}
	INT | IntArray
;


InstEncodingTwoKeyVar:
	'-' 'name' ':' name=STRING
	INDENT(
		'$inherits' ':' inherits=STRING 
	)DEDENT
;


InstRvPairEncoding:
	{InstRvPairEncoding}
	INDENT(
	'RV32' ':' rv32=InstOldEncoding
	'RV64' ':' rv64=InstOldEncoding
	)DEDENT
;



/*
 * Extension stuff (see ext_schema.json)
 */
ExtKind: 'kind' ':' kind="extension";
ExtName: 'name' ':' name=STRING;
ExtType: 'type' ':' perms=('unprivileged' | 'privileged');
ExtRviJiraIssue: 'rvi_jira_issue' ':' issue=STRING;


// versions grammar (see ext_schema.json)
ExtVersions:
	"versions" ":"
	INDENT
		elements += ExtVersionArrayElement+
	DEDENT
;

ExtVersionArrayElement:
	'-' "version" ":" version=STRING 
	INDENT (
		versionState = ExtVersionState &
		repositories = ExtVersionRepositories? &
		ratificationDate = ExtVersionRatificationDate? &
		versionChanges = ExtVersionVersionChanges? &
		url = Url? &
		versionContributors = ExtVersionContributors? &
		requirements = Requirements?
	) DEDENT
;

ExtVersionState:
	"state" ":"
	state=("development" | "frozen" | "public-review" |
		   "ratification-ready" | "ratified" | "nonstandard-released")
;

ExtVersionRepositories:
	"repositories" ":"
	INDENT
		repositories += ExtVersionRepoArrayElement+
	DEDENT
;
ExtVersionRepoArrayElement: 
	'-' url=Url
	(INDENT
		"branch" ":" branch=STRING
	DEDENT)?
;

ExtVersionRatificationDate:
	"ratification_date" ":"
	date = (
	  YEAR_MONTH			// when ratification date is known
	| "unknown"				// when ratification date is unknown
	| "null")				// when version isn't ratified
;

ExtVersionVersionChanges:
	"changes" ":"
	INDENT
		changes += ExtVersionChangesArrayElement+
	DEDENT
;
ExtVersionChangesArrayElement:
	'-' change=STRING
;

ExtVersionContributors:
	"contributors" ":"
	INDENT
		contributors += ExtVersionContributorsArrayElement+
	DEDENT
;
ExtVersionContributorsArrayElement:
	'-' name=ExtVersionContributorName 
	(INDENT (
		("company" ":" company=STRING)? & 
		email=Email?
	) DEDENT)?
;
ExtVersionContributorName:
	"name" ":" name=STRING
;

/*
 * Register File Stuff (see register_file_schema.json)
 */
 RegisterKind: 'kind' ':' kind="register_file";
RegisterName: 'name' ':' name=STRING;
RegisterClass: 'register_class' ':' registerClass=STRING;
RegisterDefinedBy: 'definedBy' ':' definedBy=Condition;
RegisterLength: 'register_length' ':' registerLength=RegisterLengthType;
RegisterLengthType: intVal=RegisterLengthInt | paramName=RegisterLengthEnum;

enum RegisterLengthEnum:
	mxlen ='MXLEN' | 
	flen = 'FLEN' | 
	vlen = 'VLEN'
;

RegisterLengthInt: val=INT;
Registers:
	'registers' ':'
	INDENT
		registers += RegisterEntry+
	DEDENT
;
RegisterEntry:
	'-' 'name' ':' name=STRING
	INDENT(
		abiMnemonics = RegisterAbiMnemonics? &
		description = RegisterDescription? &
		when = RegisterWhen? &
		archRead = RegisterArchRead? &
		archWrite = RegisterArchWrite? &
		callerSaved = RegisterCallerSaved? &
		calleeSaved = RegisterCalleeSaved? &
		roles = RegisterRoles?
	)DEDENT
;

RegisterAbiMnemonics:'abi_mnemonics' ':' '[' mnemonics+=STRING (',' mnemonics+=STRING)* ']';


RegisterDescription:
	'description' ':' description=STRING
;

RegisterWhen:
	'when' ':' (
		when=RequiresNot |
		INDENT when=RequiresComposite DEDENT
	)
;

RegisterArchRead:
	'arch_read()' ':' archRead=STRING
;

RegisterArchWrite:
	'arch_write(value)' ':' archWrite=STRING
;

RegisterCallerSaved:
	'caller_saved' ':' callerSaved=Boolean
;

RegisterCalleeSaved:
	'callee_saved' ':' calleeSaved=Boolean
;

RegisterRoles:'roles' ':' '[' roles+=RegisterRole (',' roles+=RegisterRole)* ']';

RequiresEntry:
	ExtensionRequirement | RequiresComposite
;


ExtensionRequirement:
	'name' ':' name=STRING 
	(INDENT? 'version' ':' version=RegisterVersionRequirements DEDENT?)?
;

RegisterVersionRequirements:
	versionSingle=RegVersionRequirementString | versionArray=RegVersionRequirementArray
;

RegVersionRequirementArray:
	'[' versions+=RegVersionRequirementString (',' versions+=RegVersionRequirementString)* ']'
;

RegVersionRequirementString:
	version=STRING
;

RequiresComposite:
	RequiresAnyOf | RequiresAllOf | RequiresOneOf | RequiresNot
;

RequiresNot:
	'not' ':' '{' 'name' ':' name=STRING '}'
;
RequiresAnyOf:
	'anyOf' ':'
	INDENT
		('-' entries += RequiresEntry)+
	DEDENT
;

RequiresAllOf:
	'allOf' ':'
	INDENT
		('-' entries += RequiresEntry)+
	DEDENT
;

RequiresOneOf:
	'oneOf' ':'
	INDENT
		('-' entries += RequiresEntry)+
	DEDENT
;


enum RegisterRole:
	ZERO = 'zero' |
	RETURN_ADDRESS = 'return_address' |
	ALTERNATE_LINK_REGISTER = 'alternate_link_register' |
	STACK_POINTER = 'stack_pointer' |
	GLOBAL_POINTER = 'global_pointer' |
	THREAD_POINTER = 'thread_pointer' |
	FRAME_POINTER = 'frame_pointer' |
	RETURN_VALUE = 'return_value' |
	ARGUMENT = 'argument' |
	TEMPORARY = 'temporary'
;
