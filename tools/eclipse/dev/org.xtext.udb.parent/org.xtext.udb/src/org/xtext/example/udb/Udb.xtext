/*
 * Interrupt Code stuff (see interrupt_code_schema.json)
 */
IntrptCodeKind:'kind' ':' kind="interrupt_code";
IntrptCodeName:'name' ':' name=STRING;
IntrptCodeNum:'num' ':' num=INT; 



/*
 * Exception Code stuff (see exception_code_schema.json)
 */
ECKind: 'kind' ':' kind="exception_code";
ECName: 'name' ':' name=STRING;
Num: 'num' ':' num=INT;



/* 
 * Inst Opcode Code stuff (see inst_opcode_code_schema.json) 
 */
InstOpcodeKind: 'kind' ':' kind="instruction_opcode";
InstOpcodeName: 'name' ':' name=STRING;
InstOpcodeData: 'data' ':'
	INDENT(
		('display_name' ':' displayName=STRING) &
		('value' ':' (value=Bin | value=Hex | valueInt=INT)) &
		('location' ':' (location=Range | locationInt=INT))? &
		('parent_of' ':' (parentOf=StringArray | parentOfString=STRING))?
		)DEDENT
;



/*
 * Inst Var Type stuff (see inst_variable_type_schema.json)
 */

InstVarTypeKind:
	'kind' ':' kind='instruction_variable_type'
;
InstVarTypeName:
	'name' ':' name=STRING
;
InstVarTypeType:
	'type' ':' type=VarTypeEnum
;
RegisterFile:
	'register_file' ':' registerFile=RegisterFileEnum
;
InstVarTypeAccess:
	'access' ':' access=AccessEnum
;

enum AccessEnum:
	R = 'R' |
	W = 'W' |
	RW = 'RW'
;
enum VarTypeEnum:
	REGISTER_REFERENCE = 'register_reference' |
	IMMEDIATE = 'immediate'
;
enum RegisterFileEnum:
	X = 'X' |
	F = 'F' |
	V = 'V'
;

/*
 * Manual stuff (see manual_schema.json)
 */

SpecState: 'state' ':' state=stateEnum;

enum stateEnum:
	DEVELOPMENT = 'development' |
	FROZEN = 'frozen' |
	PUBLICREVIEW = 'public-review' |
	RATIFICATIONREADY = 'ratification-ready' |
	RATIFIED = 'ratified' |
	NONSTANDARDRELEASED = 'nonstandard-released' 
;

MarketingName: 'marketing_name' ':' marketingName=STRING;

ManualName: 'name' ':' name=STRING;

ManualKind: 'kind' ':' kind="manual";



/*
 * Manual Version stuff (see manual_version_schema.json)
 */
 
ManualVersionKind: 'kind' ':' kind="manual_version";
ManualVersionName: 'name' ':' name=STRING;
ManualVersionManual: 'manual' ':' '{' '$ref:' ref=STRING  '}';
ManualVersionVersion: 'version' ':' version=STRING;
MarketingVersion: 'marketing_version' ':' marketingVersion=STRING;
ManualVersionState: 'state' ':' state=SpecStateEnum;

enum SpecStateEnum:
	DEVELOPMENT = 'development' |
	FROZEN = 'frozen' |
	PUBLIC_REVIEW = 'public-review' |
	RATIFICATION_READY = 'ratification-ready' |
	RATIFIED = 'ratified' |
	NONSTANDARD_RELEASED = 'nonstandard-released'
;

ManualVersionVolumes: 
	'volumes' ':' 
	INDENT
		volumes+=VolumesArr+
	DEDENT
;

VolumesArr:
	'-' 'title' ':' title=STRING
	INDENT (
		('description' ':' desc=STRING) &
		('chapters' ':' 
			INDENT
			(chapters+=ChapterElement+)
			DEDENT)? &
		('authors' ':' 
			INDENT
			(authors+=AuthorElement+)
			DEDENT) &
		('extensions' ':'
			INDENT
			(extension+=ExtensionElement+)
			DEDENT)? &
		('changes' ':'
			INDENT
			(change+=ChangeString+)
			DEDENT)?
		
	)DEDENT
;

ChangeString:
	'-' changeString=STRING
;

ExtensionElement:
	'-' '{' 'name' ':' name=STRING ',' 'version' ':' version=STRING '}'
;

AuthorElement:
	'-' 'name' ':' name=STRING
	INDENT(
		('email' ':' email=STRING)? &
		('organization' ':' 
			INDENT
			(org=OrgInfo)
			DEDENT
		)?
	)DEDENT
;

OrgInfo:
	'name' ':' name=STRING &
	'url' ':' url=STRING
;

ChapterElement:	 '-' element=STRING;


IsaManualTree: 'isa_manual_tree' ':' tree=STRING;

UsesIsaManual: 'uses_isa_manual' ':' uses=Boolean;

/* 
 * Profile_Family stuff (see profile_family_schema.json) 
 */
 
PFKind:
	'kind' ':' kind='profile_family' 
;

PFName:
	'name' ':' name=STRING
;

PFMarketingName:
	'marketing_name' ':' marketingName=STRING
;

PFNamingScheme:
	'naming_scheme' ':' namingScheme=STRING
;





//Condition: placeholder=STRING;
/*
 * Conditions
 * TODO: currently breaks syntax errors
 */
Condition: YAMLCondition | IDLCondition | ConditionArray;

ConditionArray: ConditionArrayList | ConditionNot;

ConditionArrayList:
	( 'allOf' ':'
	| 'anyOf' ':'
	| 'oneOf' ':'
	| 'noneOf' ':') &
	(INDENT
		condArray+=ConditionElement+
	DEDENT)
;

// Mandates only one element for 'not'
ConditionNot: 
	'not' ':'
	INDENT
		condArray=ConditionElement
	DEDENT
;

ConditionElement: '-' cond=Condition;

YAMLCondition: 
	ExtensionCondition | XLenCondition | ParamCondition | YAMLArray | YAMLIfThen
;

YAMLArray: YAMLArrayList | YAMLNot;

YAMLArrayList:
	( 'allOf' ':'
	| 'anyOf' ':'
	| 'oneOf' ':'
	| 'noneOf' ':') &
	(INDENT
		yamlArray+=YAMLElement+
	DEDENT)
;

// Mandates only one element for 'not'
YAMLNot:
	'not' ':'
	INDENT
		yamlArray=YAMLElement
	DEDENT
;

YAMLElement: '-' yamlArrayElement=YAMLCondition;

YAMLIfThen:
	('if' ':' 
	INDENT
		ifCond=YAMLCondition 
	DEDENT) &
	('then' ':'
	INDENT
		thenCond=YAMLCondition
	DEDENT)
;

IDLCondition:
	'idl()' ':' idl=Idl
;

ExtensionCondition:
	'extension' ':'
	INDENT
		extCond=Extension
	DEDENT
;

Extension:
	 requirement=ExtRequirement
	| array=ExtArray
	| ifThen=ExtIfThen
;

ExtRequirement:
	'name' ':' name=STRING &
	(version=ExtVersion)?
;

ExtVersion: IndentVersion | NoIndentVersion;
IndentVersion: 
	INDENT
		'version' ':' verReqs=VersionRequirements
	DEDENT
;
NoIndentVersion: 'version' ':' verReqs=VersionRequirements;

VersionRequirements:
	versionReq=STRING 
;

ExtArray: ExtArrayList | ExtNot;

ExtArrayList:
	( 'allOf' ':'
	| 'anyOf' ':'
	| 'oneOf' ':'
	| 'noneOf' ':') &
	(INDENT
		extArray+=ExtArrayElement+ 
	DEDENT)
;

// Mandates only one element for 'not'
ExtNot: 
	'not' ':' 
	INDENT
		extNotArray=ExtArrayElement
	DEDENT
;

ExtArrayElement: '-' extConds=Extension;

ExtIfThen: 
	('if' ':' 
	INDENT
		ifCond=Condition 
	DEDENT) &
	('then' ':'
	INDENT
		thenCond=ExtensionCondition
	DEDENT)
;


ParamCondition:
	'param' ':'
	INDENT
		param=Param 
	DEDENT
;

Param: ParamFieldsList | ParamArray;

ParamArray: ParamArrayList | ParamNot;

ParamArrayList:
	( 'allOf' ':' 
	| 'anyOf' ':' 
	| 'oneOf' ':' 
	| 'noneOf' ':') &
	(INDENT
		paramArray+=ParamArrayElement+
	DEDENT)
;

// Mandates only one element for 'not'
ParamNot: 
	'not' ':'
	INDENT
		paramArray=ParamArrayElement
	DEDENT
;

ParamArrayElement: '-' paramElement=Param;

ParamFieldsList:
	'name' ':' name=STRING &
	(INDENT
		paramFieldsList+=ParamFields+
	DEDENT)?
;

ParamFields: 
	(ParamIndex |
	ParamSize |
	ParamEqual |
	ParamOneOf |
	ParamNotEqual |
	ParamGreaterThan |
	ParamLessThan |
	ParamGreaterEqual | 
	ParamLessEqual |
	ParamIncludes |
	ParamReason)
;

ParamIndex: 'index' ':' index=INT;
ParamSize: 'size' ':' size=Boolean;
ParamEqual: 'equal' ':' (equalInt=INT | equalBool=Boolean | equalStr=STRING);
ParamOneOf: 
	'oneOf' ':' 
	INDENT
		oneOf+=ParamOneOfElement+
	DEDENT;
ParamOneOfElement: '-' (paramInt=INT|paramStr=ID); 
ParamNotEqual: 'notEqual' ':' (notEqualInt=INT | notEqualStr=ID | notEqualBool=Boolean);
ParamGreaterThan: 'greaterThan' ':' greaterThan=INT;
ParamLessThan: 'lessThan' ':' lessThan=INT;
ParamGreaterEqual: 'greaterThanOrEqual' ':' greaterEqual=INT;
ParamLessEqual: 'lessThanOrEqual' ':' lessEqual=INT;
ParamIncludes: 'includes' ':' (includeInt=INT | includeStr=ID);
ParamReason: 'reason' ':' reason=STRING;

XLenCondition: 'xlen' ':' xlen=INT;



/*
 * Keywords
 */
UndefinedLegal: "UNDEFINED_LEGAL";
Boolean returns ecore::EBoolean: "true" | "false";



/*
 * Helpers
 */
Array: '[' names+=ID (',' names+=ID)+ ']';

IntArray: '[' element+=INT (',' element+=INT) + ']';


StringArray: '[' item+=STRING (',' item+=STRING) + ']';

MultilineString: '|' value=STRING;



/*
 * Hex & Binary
 */
Hex: value=HEX_VALUE;
terminal HEX_VALUE returns ecore::EInt:
	('0x' | '0X')
	('0'..'9' | 'A'..'F' | 'a'..'f')
	(('0'..'9' | 'A'..'F' | 'a'..'f' | '_')*('0'..'9' | 'A'..'F' | 'a'..'f'))?
;

Bin: value=BIN_VALUE;
terminal BIN_VALUE returns ecore::EInt:
	('0b' | '0B')
	('0'|'1')
	(('0' | '1' | '_')*('0' | '1'))?
;

/*
 * Terminals
 */
terminal YEAR_MONTH:
	(('20')('0'..'9')('0'..'9')'-'
	  ('0'('1'..'9') | '1'('0'..'2')))
;

// For whitespace awareness
terminal INDENT: 'synthetic:INDENT';
terminal DEDENT: 'synthetic:DEDENT';


@Override
terminal SL_COMMENT: '#' !('\n'|'\r')*;

@Override
terminal WS: ('\r'|'\n'|'\t'|' ')+;

@Override
terminal ID: '^'?('a'..'z'|'A'..'Z'|'_') ('a'..'z'|'A'..'Z'|'_'|'0'..'9'|'.')*;
