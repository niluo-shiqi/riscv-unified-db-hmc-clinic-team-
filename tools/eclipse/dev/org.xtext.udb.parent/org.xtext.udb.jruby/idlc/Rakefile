# frozen_string_literal: true

require "pathname"
require "fileutils"

IDLC_ROOT = Kernel.__dir__

namespace :release do
  namespace :idlc do
    desc "Prepare a copy of the idlc gem for release under gen/idlc_gem (or IDLC_GEM_GEN_DIR)"
    task :prepare do
      idlc_gem_src = Pathname.new(IDLC_ROOT)
      repo_root = (idlc_gem_src / ".." / ".." / "..").realpath
      idlc_gem_dst = Pathname.new(ENV.fetch("IDLC_GEM_GEN_DIR", (repo_root / "gen" / "idlc_gem").to_s))

      puts "Preparing idlc gem release copy at #{idlc_gem_dst}"

      # Remove existing destination
      FileUtils.rm_rf(idlc_gem_dst)

      # Before copying, record the realpath of each top-level symlink in the source
      # so we can resolve them after the copy (the symlinks point into the monorepo
      # and would be broken at a different directory depth).
      symlink_targets = {}
      idlc_gem_src.children.select(&:symlink?).each do |s|
        symlink_targets[s.basename.to_s] = s.realpath
      end

      # Copy the gem source directory contents (symlinks are copied as symlinks).
      # Copy children individually so contents land directly in idlc_gem_dst/
      # rather than in idlc_gem_dst/idlc/ (cp_r behaviour when dst already exists).
      FileUtils.mkdir_p(idlc_gem_dst)
      FileUtils.cp_r(idlc_gem_src.children.map(&:to_s), idlc_gem_dst.to_s)

      # Remove Gemfile and Gemfile.lock from the copy.
      # These reference local gem paths that only exist inside the monorepo
      # and would cause `gem build` to fail elsewhere.
      FileUtils.rm_f(idlc_gem_dst / "Gemfile")
      FileUtils.rm_f(idlc_gem_dst / "Gemfile.lock")

      # Resolve (or remove) each top-level symlink in the copy
      symlink_targets.each do |name, target|
        dst_entry = idlc_gem_dst / name
        FileUtils.rm_rf(dst_entry)
        # Skip entries whose target doesn't exist
        next unless target.exist?

        if target.directory?
          FileUtils.cp_r(target, dst_entry)
        else
          FileUtils.cp(target, dst_entry)
        end
      end

      puts "idlc gem release copy ready at #{idlc_gem_dst}"
    end
  end
end

namespace :test do
  namespace :idlc do
    task :ruby do
      Dir.chdir(IDLC_ROOT) do
        sh "ruby -Ilib:test test/test_*.rb"
      end
    end
  end
end

namespace :test do
  namespace :idlc do
    desc "Type check the Ruby IDL source code"
    task :sorbet  do
      Bundler.with_unbundled_env do
        Dir.chdir(IDLC_ROOT) do
          Udb.logger.info "Type checking idlc gem"
          sh "BUNDLE_GEMFILE=#{IDLC_ROOT}/Gemfile BUNDLE_FROZEN=1 bundle exec srb tc"
        end
      end
    end

    task :sorbet_coverage do
      Bundler.with_unbundled_env do
        Dir.chdir(IDLC_ROOT) do
          sh "BUNDLE_GEMFILE=#{IDLC_ROOT}/Gemfile BUNDLE_FROZEN=1 bundle exec spoom srb coverage"
        end
      end
    end

    desc "Run all unit tests"
    task :unit  do
      Dir.chdir(IDLC_ROOT) do |d|
        sh "bundle exec ruby test/run.rb"
      end
    end
  end
end
