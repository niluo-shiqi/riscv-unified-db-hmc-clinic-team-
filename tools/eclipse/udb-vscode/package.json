{
  "name": "udb-vscode",
  "version": "3.0.2",
  "publisher": "HarveyMuddClinicTeam",
  "private": true,
  "engines": {
    "vscode": "^1.109.0"
  },
  "description": "Added support for instruction, extension, and CSR schemas with cross-referencing across schema definitions.",
  "activationEvents": [],
  "contributes": {
    "languages": [
      {
        "id": "udb",
        "aliases": [
          "UDB"
        ],
        "extensions": [
          ".udb"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "udb",
        "scopeName": "source.udb",
        "path": "./syntaxes/udb.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "UDB",
      "properties": {
        "udb.javaPath": {
          "type": "string",
          "default": "java",
          "description": "Path to the Java executable used to run the language server."
        }
      }
    }
  },
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p .",
    "test": "npm run compile && node ./out/test/runTests.js",
    "watch": "tsc -w",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/glob": "8.1.0",
    "@types/mocha": "10.0.10",
    "@types/node": "24.10.12",
    "@types/vscode": "1.109.0",
    "@vscode/test-electron": "2.5.2",
    "glob": "7.2.3",
    "mocha": "^7.2.0",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/niluo-shiqi/riscv-unified-db-hmc-clinic-team-"
  }
}
